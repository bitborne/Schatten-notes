---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/phycat-abyss.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* ===== 莫兰迪配色变量（关于页面） ===== */
			.morandi-theme {
				--morandi-blue: #6b8cae;
				--morandi-green: #8faa8f;
				--morandi-purple: #a68fac;
				--morandi-warm: #b8a090;
				--morandi-cool: #7a8b99;
			}

			.morandi-theme .article-container {
				background:
					radial-gradient(at 0% 0%, rgba(107, 140, 174, 0.08) 0, transparent 50%),
					radial-gradient(at 100% 100%, rgba(143, 170, 143, 0.06) 0, transparent 50%),
					var(--bg-abyss);
			}

			.morandi-theme .back-link:hover {
				color: var(--morandi-blue);
			}

			.morandi-theme .article-title {
				background: linear-gradient(135deg, #e8e8e8 0%, var(--morandi-blue) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			.morandi-theme .text-muted {
				color: var(--morandi-cool);
			}

			.article-container {
				background-color: var(--bg-abyss);
				min-height: 100vh;
			}

			/* ===== 阅读进度条 ===== */
			.read-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 2px;
				background: linear-gradient(90deg, var(--primary-cyan), var(--primary-purple));
				z-index: 10000;
				transition: width 0.1s linear;
			}

			.read-progress::after {
				content: '';
				position: absolute;
				right: 0;
				top: 0;
				width: 100px;
				height: 100%;
				background: linear-gradient(90deg, transparent, var(--primary-cyan));
				filter: blur(4px);
			}

			/* ===== 文章头部 ===== */
			.article-header {
				padding: 8rem 0 3rem;
				max-width: 900px;
				margin: 0 auto;
				padding-left: 1.5rem;
				padding-right: 1.5rem;
				position: relative;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 2rem;
				transition: var(--transition-base);
				text-decoration: none;
			}

			.back-link:hover {
				color: var(--primary-cyan);
			}

			.title-section {
				margin-bottom: 2rem;
			}

			.article-title {
				font-size: clamp(2rem, 5vw, 3.5rem);
				font-weight: 800;
				line-height: 1.15;
				margin-bottom: 1.5rem;
				color: var(--text-primary);
				letter-spacing: -0.02em;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-secondary);
				flex-wrap: wrap;
			}

			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.4rem;
			}

			.text-muted {
				opacity: 0.6;
			}

			/* ===== 文章布局 ===== */
			.article-wrapper {
				max-width: 1200px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 1fr 280px;
				gap: 3rem;
				padding: 0 1.5rem;
			}

			@media (max-width: 1100px) {
				.article-wrapper {
					grid-template-columns: 1fr;
				}
			}

			/* ===== 主内容区 ===== */
			.article-main {
				max-width: 720px;
			}

			.hero-image {
				margin-bottom: 3rem;
				border-radius: var(--radius-md);
				overflow: hidden;
				border: 1px solid var(--border-color);
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
			}

			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
			}

			.article-content {
				padding-bottom: 6rem;
			}

			/* Typora Abyss Content Overrides */
			#write {
				background: transparent !important;
				padding: 0 !important;
				box-shadow: none !important;
				color: var(--text-primary) !important;
			}

			:global(.prose) {
				font-size: 1.1rem;
				line-height: 1.85;
			}

			/* ===== 浮动目录 ===== */
			.toc-sidebar {
				position: sticky;
				top: 100px;
				height: fit-content;
				padding: 1.5rem;
				background: rgba(15, 13, 26, 0.6);
				backdrop-filter: blur(10px);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: 12px;
			}

			@media (max-width: 1100px) {
				.toc-sidebar {
					display: none;
				}
			}

			.toc-title {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.75rem;
				color: var(--text-muted);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 1rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
			}

			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.toc-item {
				margin: 0.5rem 0;
			}

			.toc-item-h2 {
				margin-left: 0;
			}

			.toc-item-h3 {
				margin-left: 1rem;
			}

			.toc-link {
				display: block;
				padding: 0.4rem 0.75rem;
				color: var(--text-secondary);
				font-size: 0.85rem;
				text-decoration: none;
				border-radius: 6px;
				transition: all 0.2s;
				border-left: 2px solid transparent;
			}

			.toc-link:hover {
				color: var(--text-primary);
				background: rgba(255, 255, 255, 0.03);
			}

			.toc-link.active {
				color: var(--primary-cyan);
				background: rgba(0, 243, 255, 0.05);
				border-left-color: var(--primary-cyan);
			}

			/* ===== 代码块增强 ===== */
			:global(pre.astro-code) {
				position: relative !important;
				padding: 2rem 0 0 0 !important;
				border-radius: 10px !important;
				background: #0f111a !important;
				border: 1px solid rgba(255, 255, 255, 0.06) !important;
				margin: 1.5rem 0 !important;
				overflow: hidden !important;
			}

			:global(pre.astro-code::before) {
				content: attr(data-language);
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 2rem;
				background: rgba(255, 255, 255, 0.02);
				border-bottom: 1px solid rgba(255, 255, 255, 0.04);
				display: flex;
				align-items: center;
				padding: 0 1rem 0 4rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.7rem;
				color: var(--text-muted);
				text-transform: uppercase;
			}

			/* 复制按钮 - 高对比度可见设计 */
			.code-copy-btn {
				position: absolute;
				top: 0.35rem;
				right: 0.5rem;
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(255, 255, 255, 0.12);
				border: 1px solid rgba(255, 255, 255, 0.2);
				border-radius: 5px;
				color: rgba(255, 255, 255, 0.9);
				cursor: pointer;
				opacity: 0.85;
				transition: all 0.2s;
				z-index: 20;
			}

			:global(pre.astro-code:hover) .code-copy-btn {
				opacity: 1;
				background: rgba(255, 255, 255, 0.18);
			}

			.code-copy-btn:hover {
				background: rgba(0, 243, 255, 0.25) !important;
				color: #fff;
				border-color: rgba(0, 243, 255, 0.5);
				transform: scale(1.05);
			}

			.code-copy-btn.copied {
				background: rgba(34, 197, 94, 0.25) !important;
				color: #4ade80;
				border-color: rgba(74, 222, 128, 0.5);
			}

			/* 代码窗口按钮 */
			:global(pre.astro-code::after) {
				content: '';
				position: absolute;
				top: 0.65rem;
				left: 1rem;
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: #ff5f56;
				box-shadow:
					14px 0 0 #ffbd2e,
					28px 0 0 #27c93f;
			}

			/* 阅读时间估计 */
			.reading-time {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--text-muted);
			}
		</style>
	</head>

	<body>
		<div class="read-progress" id="readProgress"></div>

		<div class={`article-container ${title === 'About Me' ? 'morandi-theme' : ''}`}>
			<Header />

			<main>
				<article>
					<header class="article-header">
						<a href="/blog" class="back-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<polyline points="15 18 9 12 15 6"></polyline>
							</svg>
							返回归档
						</a>
						<div class="title-section">
							<h1 class="article-title" id="articleTitle">{title}</h1>
							<div class="article-meta">
								<div class="meta-item">
									<span class="text-muted">发布于</span>
									<FormattedDate date={pubDate} />
								</div>
								{updatedDate && (
									<div class="meta-item">
										<span class="text-muted">更新于</span>
										<FormattedDate date={updatedDate} />
									</div>
								)}
								<div class="meta-item reading-time" id="readingTime">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"></circle>
										<polyline points="12 6 12 12 16 14"></polyline>
									</svg>
									<span id="readingTimeText">计算中...</span>
								</div>
							</div>
						</div>
					</header>

					<div class="article-wrapper">
						<div class="article-main">
							{heroImage && (
								<div class="hero-image">
									<Image width={1000} height={500} src={heroImage} alt={title} />
								</div>
							)}

							<div class="article-content">
								<div id="write" class="prose">
									<slot />
								</div>
							</div>
						</div>

						<aside class="toc-sidebar" id="tocSidebar">
							<div class="toc-title">目录导航</div>
							<nav class="toc-nav">
								<ul class="toc-list" id="tocList">
									<!-- 动态生成 -->
								</ul>
							</nav>
						</aside>
					</div>
				</article>
			</main>

			<Footer />
		</div>

		<script>
			// ===== 阅读进度条 =====
			function updateReadingProgress() {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = (scrollTop / docHeight) * 100;
				document.getElementById('readProgress')!.style.width = `${progress}%`;
			}

			window.addEventListener('scroll', updateReadingProgress, { passive: true });

			// ===== 阅读时间计算 =====
			function calculateReadingTime() {
				const articleText = document.getElementById('write')?.textContent || '';
				const wordCount = articleText.trim().length;
				const readingTime = Math.ceil(wordCount / 300);
				const text = readingTime < 1 ? '少于 1 分钟' : `${readingTime} 分钟阅读`;
				document.getElementById('readingTimeText')!.textContent = text;
			}

			// ===== 生成目录 =====
			function generateTOC() {
				const article = document.getElementById('write');
				const tocList = document.getElementById('tocList');
				if (!article || !tocList) return;

				const headings = article.querySelectorAll('h2, h3');
				if (headings.length === 0) {
					document.getElementById('tocSidebar')!.style.display = 'none';
					return;
				}

				headings.forEach((heading, index) => {
					const id = `heading-${index}`;
					heading.id = id;

					const li = document.createElement('li');
					li.className = `toc-item toc-item-${heading.tagName.toLowerCase()}`;

					const link = document.createElement('a');
					link.className = 'toc-link';
					link.href = `#${id}`;
					link.textContent = heading.textContent;
					link.dataset.target = id;

					link.addEventListener('click', (e) => {
						e.preventDefault();
						heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});

					li.appendChild(link);
					tocList.appendChild(li);
				});
			}

			// ===== 高亮当前章节 =====
			function highlightCurrentHeading() {
				const headings = document.querySelectorAll('#write h2, #write h3');
				const tocLinks = document.querySelectorAll('.toc-link');

				let currentId = '';
				headings.forEach(heading => {
					const rect = heading.getBoundingClientRect();
					if (rect.top <= 120) {
						currentId = heading.id;
					}
				});

				tocLinks.forEach(link => {
					link.classList.toggle('active', link.dataset.target === currentId);
				});
			}

			window.addEventListener('scroll', highlightCurrentHeading, { passive: true });

			// ===== 代码块复制按钮 =====
			function addCopyButtons() {
				const codeBlocks = document.querySelectorAll('pre.astro-code');

				codeBlocks.forEach(block => {
					const button = document.createElement('button');
					button.className = 'code-copy-btn';
					button.innerHTML = `
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
							<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
						</svg>
					`;
					button.setAttribute('aria-label', '复制代码');

					button.addEventListener('click', async () => {
						const code = block.querySelector('code')?.textContent || '';
						try {
							await navigator.clipboard.writeText(code);
							button.classList.add('copied');
							button.innerHTML = `
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
							`;
							setTimeout(() => {
								button.classList.remove('copied');
								button.innerHTML = `
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
										<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
									</svg>
								`;
							}, 2000);
						} catch (err) {
							console.error('复制失败:', err);
						}
					});

					block.appendChild(button);
				});
			}

			// ===== 自动转换 GFM 警告框标记 =====
			function transformAlerts() {
				const blocks = document.querySelectorAll('#write blockquote');
				blocks.forEach(block => {
					const firstP = block.querySelector('p');
					if (!firstP) return;

					const content = firstP.textContent || '';
					const match = content.match(/^\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/i);

					if (match) {
						const type = match[1].toLowerCase();
						block.classList.add('markdown-alert', `markdown-alert-${type}`);

						firstP.innerHTML = firstP.innerHTML.replace(/^\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/i, '').trim();

						if (!firstP.textContent?.trim() && !firstP.querySelector('img')) {
							firstP.remove();
						}
					}
				});
			}

			// ===== 初始化 =====
			document.addEventListener('DOMContentLoaded', () => {
				calculateReadingTime();
				generateTOC();
				addCopyButtons();
				transformAlerts();
				highlightCurrentHeading();
			});
		</script>
	</body>
</html>
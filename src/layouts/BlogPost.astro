---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<link rel="stylesheet" href="/src/styles/phycat-abyss.css" />
		<style>
			.article-container {
				background-color: var(--bg-abyss);
				min-height: 100vh;
			}

			.article-header {
				padding: 6rem 0 3rem;
				max-width: 900px;
				margin: 0 auto;
				padding-left: 1.5rem;
				padding-right: 1.5rem;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 2rem;
				transition: var(--transition-base);
			}

			.back-link:hover {
				color: var(--primary-cyan);
			}

			.title-section {
				margin-bottom: 2rem;
			}

			.article-title {
				font-size: 3rem;
				font-weight: 800;
				line-height: 1.1;
				margin-bottom: 1.5rem;
				color: var(--text-primary);
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.9rem;
				color: var(--text-secondary);
			}

			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.4rem;
			}

			.hero-image {
				max-width: 1000px;
				margin: 0 auto 4rem;
				border-radius: var(--radius-md);
				overflow: hidden;
				border: 1px solid var(--border-color);
				box-shadow: var(--shadow-soft);
			}

			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
			}

			.article-content {
				max-width: 900px;
				margin: 0 auto;
				padding: 0 1.5rem 6rem;
			}

			/* Typora Abyss Content Overrides */
			#write {
				background: transparent !important;
				padding: 0 !important;
				box-shadow: none !important;
				color: var(--text-primary) !important;
			}

			:global(.prose) {
				font-size: 1.1rem;
				line-height: 1.8;
			}
		</style>
	</head>

	<body>
		<div class="article-container">
			<Header />

			<main>
				<article>
					<header class="article-header">
						<a href="/blog" class="back-link">
							<span>&lt;--</span> RETURN_TO_ARCHIVE
						</a>
						<div class="title-section">
							<h1 class="article-title">{title}</h1>
							<div class="article-meta">
								<div class="meta-item">
									<span class="text-muted">PUBLISHED:</span>
									<FormattedDate date={pubDate} />
								</div>
								{updatedDate && (
									<div class="meta-item">
										<span class="text-muted">UPDATED:</span>
										<FormattedDate date={updatedDate} />
									</div>
								)}
							</div>
						</div>
					</header>

					{heroImage && (
						<div class="hero-image">
							<Image width={1000} height={500} src={heroImage} alt={title} />
						</div>
					)}

					<div class="article-content">
						<div id="write" class="prose">
							<slot />
						</div>
					</div>
				</article>
			</main>

			<Footer />
		</div>

		<script>
			// 自动转换 GFM 警告框标记
			function transformAlerts() {
				const blocks = document.querySelectorAll('#write blockquote');
				blocks.forEach(block => {
					const firstP = block.querySelector('p');
					if (!firstP) return;

					const content = firstP.textContent || '';
					const match = content.match(/^\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/i);
					
					if (match) {
						const type = match[1].toLowerCase();
						block.classList.add('markdown-alert', `markdown-alert-${type}`);
						
						// 移除标记文本
						firstP.innerHTML = firstP.innerHTML.replace(/^\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/i, '').trim();
						
						// 如果移除后 p 为空，则删除该 p
						if (!firstP.textContent?.trim() && !firstP.querySelector('img')) {
							firstP.remove();
						}
					}
				});
			}

			// 初始化执行
			transformAlerts();
		</script>
	</body>
</html>
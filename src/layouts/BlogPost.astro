---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/phycat-abyss.css';
import '../styles/theme-toggle.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<!-- 主题初始化脚本 - 必须在页面渲染前执行 -->
		<script is:inline>
			(function() {
				// 获取保存的主题
				const savedTheme = localStorage.getItem('blog-theme');

				// 如果有保存的主题，直接使用
				if (savedTheme) {
					document.documentElement.setAttribute('data-theme', savedTheme);
				} else {
					// 否则检测系统偏好
					const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
					const theme = prefersDark ? 'dark' : 'light';
					document.documentElement.setAttribute('data-theme', theme);
				}
			})();
		</script>
		<!-- 最高优先级代码块滚动条样式 - 覆盖所有其他样式 -->
		<style is:inline>
			/* 深色模式 - 基础滚动条 */
			pre.astro-code::-webkit-scrollbar { height: 6px !important; width: 6px !important; }
			pre.astro-code::-webkit-scrollbar-track { background: transparent !important; }
			pre.astro-code::-webkit-scrollbar-corner { background: transparent !important; }
			/* 深色模式 - 滚动条 thumb 所有状态 */
			pre.astro-code::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15) !important; background-color: rgba(255,255,255,0.15) !important; border-radius: 3px !important; }
			pre.astro-code::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.25) !important; background-color: rgba(255,255,255,0.25) !important; }
			pre.astro-code::-webkit-scrollbar-thumb:active { background: rgba(255,255,255,0.35) !important; background-color: rgba(255,255,255,0.35) !important; }
			/* 深色模式 - 水平滚动条所有状态 */
			pre.astro-code::-webkit-scrollbar-thumb:horizontal { background: rgba(255,255,255,0.15) !important; background-color: rgba(255,255,255,0.15) !important; }
			pre.astro-code::-webkit-scrollbar-thumb:horizontal:hover { background: rgba(255,255,255,0.25) !important; background-color: rgba(255,255,255,0.25) !important; }
			pre.astro-code::-webkit-scrollbar-thumb:horizontal:active { background: rgba(255,255,255,0.35) !important; background-color: rgba(255,255,255,0.35) !important; }

			/* 浅色模式 - 基础滚动条 */
			[data-theme="light"] pre.astro-code::-webkit-scrollbar { height: 6px !important; width: 6px !important; }
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-track { background: transparent !important; }
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-corner { background: transparent !important; }
			/* 浅色模式 - 滚动条 thumb 所有状态 */
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb { background: rgba(0,102,204,0.3) !important; background-color: rgba(0,102,204,0.3) !important; border-radius: 3px !important; }
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:hover { background: rgba(0,102,204,0.45) !important; background-color: rgba(0,102,204,0.45) !important; }
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:active { background: rgba(0,102,204,0.55) !important; background-color: rgba(0,102,204,0.55) !important; }
			/* 浅色模式 - 水平滚动条所有状态 */
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:horizontal { background: rgba(0,102,204,0.3) !important; background-color: rgba(0,102,204,0.3) !important; }
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:horizontal:hover { background: rgba(0,102,204,0.45) !important; background-color: rgba(0,102,204,0.45) !important; }
			[data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:horizontal:active { background: rgba(0,102,204,0.55) !important; background-color: rgba(0,102,204,0.55) !important; }
		</style>
		<style>
			/* ===== 莫兰迪配色变量（关于页面） ===== */
			.morandi-theme {
				--morandi-blue: #6b8cae;
				--morandi-green: #8faa8f;
				--morandi-purple: #a68fac;
				--morandi-warm: #b8a090;
				--morandi-cool: #7a8b99;
			}

			.morandi-theme .article-container {
				background:
					radial-gradient(at 0% 0%, rgba(107, 140, 174, 0.08) 0, transparent 50%),
					radial-gradient(at 100% 100%, rgba(143, 170, 143, 0.06) 0, transparent 50%),
					var(--bg-abyss);
			}

			.morandi-theme .back-link:hover {
				color: var(--morandi-blue);
			}

			.morandi-theme .article-title {
				background: linear-gradient(135deg, #e8e8e8 0%, var(--morandi-blue) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			.morandi-theme .text-muted {
				color: var(--morandi-cool);
			}

			.article-container {
				background-color: var(--bg-abyss);
				min-height: 100vh;
			}

			/* ===== 阅读进度条 ===== */
			.read-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 2px;
				background: linear-gradient(90deg, var(--primary-cyan), var(--primary-purple));
				z-index: 10000;
				transition: width 0.1s linear;
			}

			.read-progress::after {
				content: '';
				position: absolute;
				right: 0;
				top: 0;
				width: 100px;
				height: 100%;
				background: linear-gradient(90deg, transparent, var(--primary-cyan));
				filter: blur(4px);
			}

			/* ===== 文章头部 ===== */
			.article-header {
				padding: 8rem 0 3rem;
				max-width: 900px;
				margin: 0 auto;
				padding-left: 1.5rem;
				padding-right: 1.5rem;
				position: relative;
			}

			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 2rem;
				transition: var(--transition-base);
				text-decoration: none;
			}

			.back-link:hover {
				color: var(--primary-cyan);
			}

			.title-section {
				margin-bottom: 2rem;
			}

			.article-title {
				font-size: clamp(2rem, 5vw, 3.5rem);
				font-weight: 800;
				line-height: 1.15;
				margin-bottom: 1.5rem;
				color: var(--text-primary);
				letter-spacing: -0.02em;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-secondary);
				flex-wrap: wrap;
			}

			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.4rem;
			}

			.text-muted {
				opacity: 0.6;
			}

			/* ===== 文章布局 ===== */
			.article-wrapper {
				max-width: 1280px;
				margin: 0 auto;
				display: grid;
				grid-template-columns: 1fr 360px;
				gap: 3rem;
				padding: 0 1.5rem;
			}

			@media (max-width: 1100px) {
				.article-wrapper {
					grid-template-columns: 1fr;
				}
			}

			/* ===== 主内容区 ===== */
			.article-main {
				max-width: 720px;
			}

			.hero-image {
				margin-bottom: 3rem;
				border-radius: var(--radius-md);
				overflow: hidden;
				border: 1px solid var(--border-color);
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
			}

			.hero-image img {
				width: 100%;
				height: auto;
				display: block;
			}

			.article-content {
				padding-bottom: 6rem;
			}

			/* Typora Abyss Content Overrides */
			#write {
				background: transparent !important;
				padding: 0 !important;
				box-shadow: none !important;
				color: var(--text-primary) !important;
			}

			:global(.prose) {
				font-size: 1.1rem;
				line-height: 1.85;
			}

			/* ===== 代码块增强 - 修复底部突出 ===== */
			/* 强制重置代码块基础样式，覆盖 phycat.dark.css 的冲突 */
			:global(#write pre.astro-code) {
				position: relative !important;
				padding: 0 !important;
				border-radius: 10px !important;
				background: var(--code-block-bg, #0f111a) !important;
				border: 1px solid rgba(255, 255, 255, 0.06) !important;
				margin: 1.5rem 0 !important;
				overflow: auto !important;
			}

			/* 代码块头部栏 */
			:global(#write pre.astro-code > .code-header) {
				position: sticky;
				top: 0;
				left: 0;
				right: 0;
				height: 2.2rem;
				background: rgba(255, 255, 255, 0.02);
				border-bottom: 1px solid rgba(255, 255, 255, 0.04);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 0.75rem 0 5rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.7rem;
				color: var(--text-muted);
				text-transform: uppercase;
				z-index: 10;
			}

			/* 代码内容区域 - 覆盖 phycat.dark.css 的行内代码样式 */
			:global(#write pre.astro-code > code),
			:global(#write pre.astro-code code:not(.md-fencescode)) {
				display: block !important;
				padding: 1rem 2.5rem 1rem 1.25rem !important;
				font-size: 0.875rem !important;
				line-height: 1.6 !important;
				background: transparent !important;
				/* 覆盖 phycat.dark.css 的行内代码样式 */
				border: none !important;
				margin: 0 !important;
				border-radius: 0 !important;
				transform: none !important;
				transition: none !important;
				width: auto !important;
				min-width: fit-content !important;
			}

			/* 强制覆盖 phycat.dark.css 的 hover 效果 - 增强选择器 specificity */
			:global(#write pre.astro-code > code:hover),
			:global(#write pre.astro-code:hover > code),
			:global(#write pre.astro-code > code:not(.md-fencescode):hover) {
				background: transparent !important;
				background-color: transparent !important;
				border: none !important;
				transform: none !important;
				box-shadow: none !important;
				color: inherit !important;
			}

			/* 更强力的覆盖 - 直接针对 pre.astro-code 内部的所有 code 元素 */
			:global(pre.astro-code code),
			:global(pre.astro-code code:hover) {
				background: transparent !important;
				background-color: transparent !important;
				border: none !important;
				transform: none !important;
				box-shadow: none !important;
				color: inherit !important;
				padding: 0 !important;
				margin: 0 !important;
				border-radius: 0 !important;
			}

			/* 复制按钮 - 极简设计，无背景 */
			:global(.code-header .code-copy-btn),
			.code-copy-btn {
				appearance: none !important;
				-webkit-appearance: none !important;
				-moz-appearance: none !important;
				position: absolute !important;
				top: 50% !important;
				right: 0.75rem !important;
				transform: translateY(-50%) !important;
				width: 22px !important;
				height: 22px !important;
				display: flex !important;
				align-items: center !important;
				justify-content: center !important;
				background: transparent !important;
				background-color: transparent !important;
				border: none !important;
				border-radius: 0 !important;
				color: rgba(255, 255, 255, 0.5) !important;
				cursor: pointer !important;
				opacity: 0.6 !important;
				transition: opacity 0.2s, transform 0.2s !important;
				z-index: 20 !important;
				box-shadow: none !important;
				padding: 0 !important;
				margin: 0 !important;
				font-size: 14px !important;
				line-height: 1 !important;
			}

			:global(.code-header .code-copy-btn:hover),
			.code-copy-btn:hover {
				background: transparent !important;
				background-color: transparent !important;
				border: none !important;
				border-radius: 0 !important;
				color: rgba(255, 255, 255, 0.9) !important;
				opacity: 1 !important;
				transform: translateY(-50%) scale(1.1) !important;
				box-shadow: none !important;
			}

			:global(.code-header .code-copy-btn.copied),
			.code-copy-btn.copied {
				background: transparent !important;
				background-color: transparent !important;
				border: none !important;
				border-radius: 0 !important;
				color: #4ade80 !important;
				opacity: 1 !important;
				box-shadow: none !important;
			}

			
			/* 代码块滚动条样式 - 强力覆盖 phycat 全局样式 */
			:global(pre.astro-code::-webkit-scrollbar) {
				height: 6px !important;
			}

			:global(pre.astro-code::-webkit-scrollbar-track) {
				background: transparent !important;
			}

			/* 使用多层选择器提高优先级 */
			:global(#write pre.astro-code::-webkit-scrollbar-thumb),
			:global(pre.astro-code::-webkit-scrollbar-thumb) {
				background: rgba(255, 255, 255, 0.15) !important;
				border-radius: 3px !important;
				box-shadow: none !important;
			}

			:global(#write pre.astro-code::-webkit-scrollbar-thumb:hover),
			:global(pre.astro-code::-webkit-scrollbar-thumb:hover) {
				background: rgba(255, 255, 255, 0.25) !important;
				box-shadow: none !important;
			}

			:global(#write pre.astro-code::-webkit-scrollbar-thumb:active),
			:global(pre.astro-code::-webkit-scrollbar-thumb:active) {
				background: rgba(255, 255, 255, 0.35) !important;
				box-shadow: none !important;
			}

			/* 浅色模式下代码块滚动条 - 使用更高优先级 */
			:global([data-theme="light"] #write pre.astro-code::-webkit-scrollbar-thumb),
			:global([data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb) {
				background: rgba(0, 102, 204, 0.3) !important;
				box-shadow: none !important;
			}

			:global([data-theme="light"] #write pre.astro-code::-webkit-scrollbar-thumb:hover),
			:global([data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:hover) {
				background: rgba(0, 102, 204, 0.45) !important;
				box-shadow: none !important;
			}

			:global([data-theme="light"] #write pre.astro-code::-webkit-scrollbar-thumb:active),
			:global([data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:active) {
				background: rgba(0, 102, 204, 0.55) !important;
				box-shadow: none !important;
			}

			/* 代码窗口按钮 - 固定在头部 */
			:global(pre.astro-code > .code-header::before) {
				content: '';
				position: absolute;
				left: 1rem;
				top: 50%;
				transform: translateY(-50%);
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: #ff5f56;
				box-shadow:
					14px 0 0 #ffbd2e,
					28px 0 0 #27c93f;
			}

			/* 阅读时间估计 */
			.reading-time {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--text-muted);
			}
			/* ===== VS Code 风格目录容器 ===== */
			:global(.toc-sidebar) {
				position: sticky;
				top: 100px;
				height: fit-content;
				max-height: calc(100vh - 140px);
				overflow-y: auto;
				padding: 1rem;
				background: rgba(20, 25, 40, 0.95);
				border: 1px solid rgba(255, 255, 255, 0.06);
				border-radius: 8px;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
				font-size: 0.8125rem;
				line-height: 1.5;
				/* 隐藏滚动条但保持可滚动 */
				scrollbar-width: none;
				-ms-overflow-style: none;
			}

			:global(.toc-sidebar::-webkit-scrollbar) {
				display: none;
			}

			:global([data-theme="light"] .toc-sidebar) {
				background: rgba(255, 255, 255, 0.98);
				border-color: rgba(0, 0, 0, 0.06);
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
			}

			/* 目录标题 */
			:global(.toc-title) {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.6875rem;
				font-weight: 600;
				color: var(--text-muted);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				margin-bottom: 0.75rem;
				padding: 0 4px 0.5rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.06);
			}

			:global([data-theme="light"] .toc-title) {
				color: #8a9aa8;
				border-bottom-color: rgba(0, 0, 0, 0.06);
			}

			/* ===== 目录树容器 ===== */
			:global(.toc-tree) {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			/* ===== VS Code 风格树形目录 ===== */
			/* 统一缩进网格：每级 20px */
			:global(.toc-tree) {
				--indent-size: 20px;
				/* 使用实色避免透明度叠加导致的拼接感 */
				--line-color: #2a3a50;
				--line-hover: #3a4a60;
			}

			:global([data-theme="light"] .toc-tree) {
				--line-color: #d0d5dc;
				--line-hover: #b0b8c0;
			}

			/* 子节点容器 */
			:global(.toc-children) {
				list-style: none;
				padding: 0;
				margin: 0;
				overflow: hidden;
				transition: max-height 0.2s ease, opacity 0.15s ease;
				max-height: 2000px;
				opacity: 1;
				position: relative;
			}

			:global(.toc-children.collapsed) {
				max-height: 0;
				opacity: 0;
			}

			/* 树节点项 - 使用 flex 布局 */
			:global(.toc-item) {
				margin: 0;
				position: relative;
			}

			/* 树节点内容行 */
			:global(.toc-row) {
				display: flex;
				align-items: center;
				position: relative;
				height: 28px;
			}

			/* ===== 折叠/展开按钮 - VS Code 风格 ===== */
			:global(.toc-toggle) {
				width: 24px;
				height: 24px;
				padding: 0;
				margin-left: -4px;
				margin-right: 0;
				background: transparent;
				border: none;
				border-radius: 4px;
				cursor: pointer;
				color: var(--text-muted);
				transition: color 0.15s ease, background-color 0.15s ease;
				display: flex;
				align-items: center;
				justify-content: center;
				flex-shrink: 0;
				position: relative;
			}

			:global(.toc-toggle:hover) {
				color: var(--text-secondary);
				background: rgba(255, 255, 255, 0.06);
			}

			/* 三角形图标 */
			:global(.toc-toggle::before) {
				content: '';
				width: 0;
				height: 0;
				border-style: solid;
				border-width: 4px 0 4px 6px;
				border-color: transparent transparent transparent currentColor;
				transition: transform 0.15s ease;
				transform: rotate(0deg);
			}

			:global(.toc-toggle.expanded::before) {
				transform: rotate(90deg);
			}

			/* 占位符（用于无子节点的项） */
			:global(.toc-spacer) {
				width: 24px;
				height: 24px;
				margin-left: -4px;
				margin-right: 0;
				flex-shrink: 0;
			}

			/* ===== 树形辅助线 - VS Code 风格 ===== */
			:global(.toc-children) {
				position: relative;
			}

			/* 垂直线：从父级按钮位置开始，连接所有子项 */
			:global(.toc-children::before) {
				content: '';
				position: absolute;
				left: 8px;
				top: -14px;
				bottom: 14px;
				width: 1px;
				background: var(--line-color);
			}

			/* 水平分支线：从垂直线到链接 */
			:global(.toc-children > .toc-item) {
				position: relative;
			}

			:global(.toc-children > .toc-item::after) {
				content: '';
				position: absolute;
				left: 8px;
				top: 14px;
				width: 24px;
				height: 0;
				border-top: 1px solid var(--line-color);
			}

			:global([data-theme="light"] .toc-toggle) {
				color: #7a8a98;
			}

			:global([data-theme="light"] .toc-toggle:hover) {
				color: #5a6a78;
				background: rgba(0, 0, 0, 0.04);
			}

			/* ===== 层级缩进 ===== */
			:global(.toc-item-h2) {
				--indent-level: 0;
			}

			:global(.toc-item-h3) {
				--indent-level: 1;
			}

			:global(.toc-item-h4) {
				--indent-level: 2;
			}

			/* 根据层级计算缩进 */
			:global(.toc-row) {
				padding-left: calc(var(--indent-level, 0) * var(--indent-size));
			}

			/* ===== 辅助线 - VS Code 风格 ===== */

			/* 链接样式 */
			:global(.toc-link) {
				display: block;
				flex: 1;
				padding: 2px 6px;
				color: var(--text-secondary);
				font-size: 0.8125rem;
				line-height: 1.4;
				text-decoration: none;
				border-radius: 4px;
				transition: color 0.15s ease, background-color 0.15s ease;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			:global(.toc-link:hover) {
				color: var(--text-primary);
				background: rgba(255, 255, 255, 0.04);
			}

			:global(.toc-link.active) {
				color: var(--primary-cyan);
				background: rgba(0, 243, 255, 0.08);
				font-weight: 500;
			}

			:global([data-theme="light"] .toc-link) {
				color: #5a6a7a;
			}

			:global([data-theme="light"] .toc-link:hover) {
				color: #2a3a4a;
				background: rgba(0, 0, 0, 0.03);
			}

			:global([data-theme="light"] .toc-link.active) {
				color: var(--primary-color, #0066cc);
				background: rgba(0, 102, 204, 0.08);
			}

			/* 父级链接（H2）加粗 */
			:global(.toc-link-parent) {
				font-weight: 500;
			}

			:global(.toc-link-child) {
				font-size: 0.8125rem;
			}

			/* 目录为空时隐藏 */
			:global(.toc-tree:empty) {
				display: none;
			}

			/* 空目录状态 */
			:global(.toc-empty) {
				text-align: center;
				padding: 2rem 1rem;
				color: var(--text-muted);
				font-size: 0.8125rem;
			}

			:global([data-theme="light"] .toc-empty) {
				color: #8a9aa8;
			}
		
			/* 强制覆盖所有滚动条样式 */
			:global(pre.astro-code::-webkit-scrollbar-thumb:horizontal) {
				background: rgba(255, 255, 255, 0.15) !important;
			}

			:global([data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:horizontal) {
				background: rgba(0, 102, 204, 0.3) !important;
			}

			/* 强力覆盖 phycat 全局滚动条 active 和 hover 状态 */
			:global(pre.astro-code::-webkit-scrollbar-thumb:hover) {
				background: rgba(255, 255, 255, 0.25) !important;
				box-shadow: none !important;
			}

			:global(pre.astro-code::-webkit-scrollbar-thumb:active) {
				background: rgba(255, 255, 255, 0.35) !important;
				box-shadow: none !important;
			}

			:global([data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:hover) {
				background: rgba(0, 102, 204, 0.45) !important;
				box-shadow: none !important;
			}

			:global([data-theme="light"] pre.astro-code::-webkit-scrollbar-thumb:active) {
				background: rgba(0, 102, 204, 0.55) !important;
				box-shadow: none !important;
			}
		</style>
	</head>

	<body>
		<div class="read-progress" id="readProgress"></div>

		<div class={`article-container ${title === 'About Me' ? 'morandi-theme' : ''}`}>
			<Header showThemeToggle={true} />

			<main>
				<article>
					<header class="article-header">
						<a href="/blog" class="back-link">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<polyline points="15 18 9 12 15 6"></polyline>
							</svg>
							返回归档
						</a>
						<div class="title-section">
							<h1 class="article-title" id="articleTitle">{title}</h1>
							<div class="article-meta">
								<div class="meta-item">
									<span class="text-muted">发布于</span>
									<FormattedDate date={pubDate} />
								</div>
								{updatedDate && (
									<div class="meta-item">
										<span class="text-muted">更新于</span>
										<FormattedDate date={updatedDate} />
									</div>
								)}
								<div class="meta-item reading-time" id="readingTime">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<circle cx="12" cy="12" r="10"></circle>
										<polyline points="12 6 12 12 16 14"></polyline>
									</svg>
									<span id="readingTimeText">计算中...</span>
								</div>
							</div>
						</div>
					</header>

					<div class="article-wrapper">
						<div class="article-main">
							{heroImage && (
								<div class="hero-image">
									<Image width={1000} height={500} src={heroImage} alt={title} />
								</div>
							)}

							<div class="article-content">
								<div id="write" class="prose">
									<slot />
								</div>
							</div>
						</div>

						<aside class="toc-sidebar" id="tocSidebar">
							<div class="toc-title">目录</div>
							<nav class="toc-nav">
								<ul class="toc-tree" id="tocList" style="--parent-indent: 0;">
									<!-- 动态生成 -->
								</ul>
							</nav>
						</aside>
					</div>
				</article>
			</main>

			<Footer />
		</div>

		<script>
			// ===== 阅读进度条 =====
			function updateReadingProgress() {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = (scrollTop / docHeight) * 100;
				document.getElementById('readProgress')!.style.width = `${progress}%`;
			}

			window.addEventListener('scroll', updateReadingProgress, { passive: true });

			// ===== 阅读时间计算 =====
			function calculateReadingTime() {
				const articleText = document.getElementById('write')?.textContent || '';
				const wordCount = articleText.trim().length;
				const readingTime = Math.ceil(wordCount / 300);
				const text = readingTime < 1 ? '少于 1 分钟' : `${readingTime} 分钟阅读`;
				document.getElementById('readingTimeText')!.textContent = text;
			}

			// ===== 生成目录 - VS Code 风格树形结构 =====
			function generateTOC() {
				const article = document.getElementById('write');
				const tocList = document.getElementById('tocList');
				if (!article || !tocList) return;

				const headings = article.querySelectorAll('h2, h3');
				if (headings.length === 0) {
					document.getElementById('tocSidebar')!.style.display = 'none';
					return;
				}

				// 计算每个标题的层级
				const headingData = Array.from(headings).map((heading, index) => ({
					element: heading,
					level: heading.tagName === 'H2' ? 2 : 3,
					id: `heading-${index}`
				}));

				// 构建树结构
				const tree = [];
				let currentH2Node = null;

				headingData.forEach(item => {
					item.element.id = item.id;

					if (item.level === 2) {
						currentH2Node = { ...item, children: [] };
						tree.push(currentH2Node);
					} else if (item.level === 3 && currentH2Node) {
						currentH2Node.children.push(item);
					} else {
						// H3 without parent H2
						tree.push({ ...item, children: [] });
					}
				});

				// 渲染树
				function renderNode(node: any, parentElement: HTMLElement, indentLevel: number) {
					const li = document.createElement('li');
					li.className = `toc-item toc-item-h${node.level}`;
					li.style.setProperty('--indent-level', String(indentLevel));

					// 创建行容器
					const row = document.createElement('div');
					row.className = 'toc-row';

					// 创建折叠按钮或占位符
					if (node.children && node.children.length > 0) {
						const toggleBtn = document.createElement('button');
						toggleBtn.className = 'toc-toggle expanded';
						toggleBtn.setAttribute('aria-label', '展开/折叠');

						toggleBtn.addEventListener('click', (e) => {
							e.stopPropagation();
							const children = li.querySelector('.toc-children');
							if (children) {
								children.classList.toggle('collapsed');
								toggleBtn.classList.toggle('expanded');
								toggleBtn.classList.toggle('collapsed');
							}
						});

						row.appendChild(toggleBtn);
					} else {
						const spacer = document.createElement('span');
						spacer.className = 'toc-spacer';
						row.appendChild(spacer);
					}

					// 创建链接
					const link = document.createElement('a');
					link.className = `toc-link ${node.level === 2 ? 'toc-link-parent' : 'toc-link-child'}`;
					link.href = `#${node.id}`;
					link.textContent = node.element.textContent;
					link.dataset.target = node.id;

					link.addEventListener('click', (e) => {
						e.preventDefault();
						node.element.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});

					row.appendChild(link);
					li.appendChild(row);

					// 递归渲染子节点
					if (node.children && node.children.length > 0) {
						const childrenUl = document.createElement('ul');
						childrenUl.className = 'toc-children';
						childrenUl.style.setProperty('--parent-indent', String(indentLevel + 1));

						node.children.forEach(child => {
							renderNode(child, childrenUl, indentLevel + 1);
						});

						li.appendChild(childrenUl);
					}

					parentElement.appendChild(li);
				}

				// 从根开始渲染
				tree.forEach(node => {
					renderNode(node, tocList, 0);
				});
			}

			// ===== 高亮当前章节 =====
			function highlightCurrentHeading() {
				const headings = document.querySelectorAll('#write h2, #write h3');
				const tocLinks = document.querySelectorAll('.toc-link');

				let currentId = '';
				headings.forEach(heading => {
					const rect = heading.getBoundingClientRect();
					if (rect.top <= 120) {
						currentId = heading.id;
					}
				});

				tocLinks.forEach(link => {
					const el = link as HTMLElement;
					el.classList.toggle('active', el.dataset.target === currentId);
				});
			}

			window.addEventListener('scroll', highlightCurrentHeading, { passive: true });

			// ===== 代码块复制按钮 =====
			function addCopyButtons() {
				const codeBlocks = document.querySelectorAll('pre.astro-code');

				codeBlocks.forEach(block => {
					// 获取语言标签
					const lang = block.getAttribute('data-language') || 'code';

					// 获取代码元素
					const codeEl = block.querySelector('code');
					if (!codeEl) return;

					// 创建头部栏
					const header = document.createElement('div');
					header.className = 'code-header';

					// 创建语言标签
					const langSpan = document.createElement('span');
					langSpan.textContent = lang;

					// 创建复制按钮
					const button = document.createElement('button');
					button.className = 'code-copy-btn';
					button.innerHTML = `
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
							<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
						</svg>
					`;
					button.setAttribute('aria-label', '复制代码');

					button.addEventListener('click', async () => {
						const code = codeEl.textContent || '';
						try {
							await navigator.clipboard.writeText(code);
							button.classList.add('copied');
							button.innerHTML = `
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
							`;
							setTimeout(() => {
								button.classList.remove('copied');
								button.innerHTML = `
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
										<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
									</svg>
								`;
							}, 2000);
						} catch (err) {
							console.error('复制失败:', err);
						}
					});

					// 组装头部栏
					header.appendChild(langSpan);
					header.appendChild(button);

					// 将头部栏插入到代码块最前面
					block.insertBefore(header, block.firstChild);
				});
			}

			// ===== 自动转换 GFM 警告框标记 =====
			function transformAlerts() {
				const blocks = document.querySelectorAll('#write blockquote');
				blocks.forEach(block => {
					const firstP = block.querySelector('p');
					if (!firstP) return;

					const content = firstP.textContent || '';
					const match = content.match(/^\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/i);

					if (match) {
						const type = match[1].toLowerCase();
						block.classList.add('markdown-alert', `markdown-alert-${type}`);

						firstP.innerHTML = firstP.innerHTML.replace(/^\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/i, '').trim();

						if (!firstP.textContent?.trim() && !firstP.querySelector('img')) {
							firstP.remove();
						}
					}
				});
			}

			// ===== 初始化 =====
			document.addEventListener('DOMContentLoaded', () => {
				calculateReadingTime();
				generateTOC();
				addCopyButtons();
				transformAlerts();
				highlightCurrentHeading();
			});
		</script>
	</body>
</html>
---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero Section 增强方案 */
			.hero {
				padding: 10rem 0 6rem;
				position: relative;
				overflow: hidden;
				/* 多层光晕背景 */
				background: 
					radial-gradient(at 0% 0%, rgba(0, 243, 255, 0.12) 0, transparent 40%),
					radial-gradient(at 100% 0%, rgba(213, 0, 249, 0.1) 0, transparent 40%),
					radial-gradient(at 50% 50%, rgba(41, 121, 255, 0.05) 0, transparent 50%);
			}

			/* 科技感网格背景装饰 */
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image: 
					linear-gradient(rgba(0, 243, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(0, 243, 255, 0.03) 1px, transparent 1px);
				background-size: 50px 50px;
				-webkit-mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
				mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
				pointer-events: none;
			}

			.hero-container {
				max-width: 1000px;
				margin: 0 auto;
				padding: 0 1.5rem;
				position: relative;
				z-index: 1;
			}

			.hero-subtitle {
				font-family: 'Cascadia Code', monospace;
				color: var(--primary-cyan);
				font-size: 0.85rem;
				letter-spacing: 0.3em;
				margin-bottom: 1.5rem;
				display: block;
				text-shadow: 0 0 10px rgba(0, 243, 255, 0.5);
			}

			.hero-title {
				font-size: 4rem;
				line-height: 1.05;
				margin-bottom: 2.5rem;
				font-weight: 800;
				letter-spacing: -0.03em;
			}

			.title-gradient {
				background: linear-gradient(135deg, #fff 30%, var(--primary-cyan) 70%, var(--primary-blue));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				filter: drop-shadow(0 0 20px rgba(0, 243, 255, 0.2));
			}

			.hero-description {
				font-size: 1.2rem;
				color: var(--text-secondary);
				line-height: 1.8;
				margin-bottom: 3.5rem;
				max-width: 600px;
			}

			.hero-actions {
				display: flex;
				gap: 1.5rem;
			}

			/* Section Containers */
			.section-container {
				max-width: 1000px;
				margin: 0 auto;
				padding: 6rem 1.5rem;
			}

			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 3rem;
			}

			.section-title {
				font-size: 1.25rem;
				font-family: 'Cascadia Code', monospace;
				font-weight: 700;
				color: var(--text-primary);
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			.section-title::before {
				content: '';
				width: 4px;
				height: 1.5rem;
				background: var(--primary-cyan);
				box-shadow: 0 0 10px var(--primary-cyan);
			}

			/* 文章列表卡片：玻璃质感 */
			.post-item {
				display: grid;
				grid-template-columns: auto 1fr;
				gap: 2.5rem;
				padding: 2rem;
				margin-bottom: 1.5rem;
				background: rgba(255, 255, 255, 0.02);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: var(--radius-md);
				transition: var(--transition-base);
				text-decoration: none;
				position: relative;
				overflow: hidden;
			}

			.post-item::before {
				content: '';
				position: absolute;
				left: 0; top: 0; width: 2px; height: 100%;
				background: var(--primary-cyan);
				opacity: 0;
				transition: var(--transition-base);
			}

			.post-item:hover {
				background: rgba(255, 255, 255, 0.04);
				border-color: rgba(0, 243, 255, 0.2);
				transform: translateX(10px);
				box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
			}

			.post-item:hover::before { opacity: 1; }

			.post-date {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.8rem;
				color: var(--text-muted);
				padding-top: 0.4rem;
			}

			.post-title {
				font-size: 1.4rem;
				color: var(--text-primary);
				margin-bottom: 0.8rem;
				transition: var(--transition-base);
			}

			.post-item:hover .post-title { color: var(--primary-cyan); }

			/* 专业领域展示 */
			.expertise-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 2rem;
			}

			.expertise-card {
				padding: 2.5rem;
				background: rgba(255, 255, 255, 0.02);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: var(--radius-lg);
				transition: var(--transition-base);
				position: relative;
			}

			.expertise-card:hover {
				transform: translateY(-5px);
				background: rgba(255, 255, 255, 0.04);
			}

			.expertise-icon {
				font-size: 0.8rem;
				font-family: 'Cascadia Code', monospace;
				color: var(--primary-cyan);
				margin-bottom: 1.5rem;
				display: block;
				opacity: 0.6;
			}

			.expertise-title { font-size: 1.5rem; margin-bottom: 1.2rem; }

			/* 为不同领域添加色彩标识 */
			.expertise-card.ebpf:hover { border-color: var(--primary-cyan); box-shadow: var(--glow-cyan); }
			.expertise-card.network:hover { border-color: var(--primary-blue); box-shadow: 0 0 20px rgba(41, 121, 255, 0.2); }
			.expertise-card.io:hover { border-color: var(--primary-purple); box-shadow: var(--glow-purple); }

			.expertise-bar {
				width: 40px; height: 2px;
				margin-bottom: 1.5rem;
				background: var(--primary-cyan);
			}
			.network .expertise-bar { background: var(--primary-blue); }
			.io .expertise-bar { background: var(--primary-purple); }

			@media (max-width: 768px) {
				.hero-title { font-size: 2.8rem; }
				.post-item { grid-template-columns: 1fr; gap: 0.5rem; }
				.hero-actions { flex-direction: column; }
			}
		</style>
	</head>
	<body>
		<Header />
		
		<main>
			<section class="hero">
				<div class="hero-container">
					<div class="hero-content">
						<span class="hero-subtitle">CONNECTED // KERNEL_SPACE</span>
						<h1 class="hero-title">
							<span class="title-gradient">Tracing the Kernel,<br>One Syscall at a Time.</span>
						</h1>
						<p class="hero-description">
							专注于 Linux 内核观测、高性能网络协议栈与系统底层调优。记录技术攻坚，探索底层极限。
						</p>
						<div class="hero-actions">
							<a href="/blog" class="btn">读取文章库</a>
							<a href="/about" class="btn btn-secondary">核心配置</a>
						</div>
					</div>
				</div>
			</section>

			<section class="section-container">
				<div class="section-header">
					<h2 class="section-title">RECENT_LOGS</h2>
					<a href="/blog" style="font-size: 0.8rem; color: var(--primary-cyan); font-family: 'Cascadia Code';">VIEW_ALL_POSTS -></a>
				</div>
				<div class="posts-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-item">
							<div class="post-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div class="post-content">
								<h3 class="post-title">{post.data.title}</h3>
								<p style="font-size: 0.95rem; margin: 0;">{post.data.description || 'No metadata provided.'}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="section-container">
				<div class="section-header">
					<h2 class="section-title">EXPERTISE_DOMAINS</h2>
				</div>
				<div class="expertise-grid">
					<div class="expertise-card ebpf">
						<span class="expertise-icon">PATH: /sys/kernel/debug/tracing</span>
						<div class="expertise-bar"></div>
						<h3 class="expertise-title">eBPF & Tracing</h3>
						<p style="font-size: 0.9rem; color: var(--text-secondary);">内核级观测与 XDP 高性能处理。通过代码直接与内核对话。</p>
					</div>
					<div class="expertise-card network">
						<span class="expertise-icon">PATH: /dev/infiniband/uverbs</span>
						<div class="expertise-bar"></div>
						<h3 class="expertise-title">Kernel Network</h3>
						<p style="font-size: 0.9rem; color: var(--text-secondary);">深入 RDMA、DPDK 等用户态协议栈，挑战数据包吞吐的极限。</p>
					</div>
					<div class="expertise-card io">
						<span class="expertise-icon">PATH: /include/linux/io_uring.h</span>
						<div class="expertise-bar"></div>
						<h3 class="expertise-title">Async I/O</h3>
						<p style="font-size: 0.9rem; color: var(--text-secondary);">专注 io_uring、异步协程调度与高性能并发模型的设计与实现。</p>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
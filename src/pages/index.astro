---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* 全局动画定义 */
			@keyframes scan {
				0% { transform: translateY(-100%); }
				100% { transform: translateY(100%); }
			}

			@keyframes float {
				0%, 100% { transform: translateY(0); }
				50% { transform: translateY(-10px); }
			}

			@keyframes fadeIn {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}

			@keyframes pulse-glow {
				0%, 100% { opacity: 0.3; }
				50% { opacity: 0.6; }
			}

			/* 噪音纹理蒙版 */
			.noise-overlay {
				position: fixed;
				inset: 0;
				z-index: 9999;
				pointer-events: none;
				opacity: 0.04;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
			}

			/* ===== 极光之夜配色变量 ===== */
			:root {
				--aurora-green: #39ff14;
				--aurora-cyan: #00f5d4;
				--aurora-blue: #00bbf9;
				--aurora-purple: #9b5de5;
				--aurora-bg: #1a1423;
			}

			/* Hero Section - 极光之夜 */
			.hero {
				padding: 12rem 0 8rem;
				position: relative;
				overflow: hidden;
				background:
					radial-gradient(at 0% 20%, rgba(57, 255, 20, 0.1) 0, transparent 50%),
					radial-gradient(at 100% 0%, rgba(0, 245, 212, 0.08) 0, transparent 45%),
					radial-gradient(at 50% 100%, rgba(155, 93, 229, 0.1) 0, transparent 50%),
					radial-gradient(at 80% 80%, rgba(0, 187, 249, 0.06) 0, transparent 40%),
					var(--aurora-bg);
			}

			/* 科技感网格背景装饰 - 极光色系 */
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(57, 255, 20, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(0, 245, 212, 0.02) 1px, transparent 1px);
				background-size: 60px 60px;
				-webkit-mask-image: radial-gradient(circle at 50% 40%, black, transparent 90%);
				mask-image: radial-gradient(circle at 50% 40%, black, transparent 90%);
				pointer-events: none;
			}

			/* 扫描线效果 - 极光渐变 */
			.hero::after {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0; height: 100%;
				background: linear-gradient(to bottom,
					transparent 0%,
					rgba(57, 255, 20, 0.02) 30%,
					rgba(0, 245, 212, 0.02) 50%,
					rgba(155, 93, 229, 0.02) 70%,
					transparent 100%);
				background-size: 100% 200%;
				animation: scan 8s linear infinite;
				pointer-events: none;
				z-index: 2;
			}

			.hero-container {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 1.5rem;
				position: relative;
				z-index: 10;
			}

			.hero-content {
				animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}

			.hero-subtitle {
				font-family: 'Cascadia Code', monospace;
				background: linear-gradient(90deg, var(--aurora-green), var(--aurora-cyan));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				font-size: 0.85rem;
				letter-spacing: 0.4em;
				margin-bottom: 2rem;
				display: block;
				filter: drop-shadow(0 0 10px rgba(57, 255, 20, 0.3));
				opacity: 0.9;
			}

			.hero-title {
				font-size: clamp(3rem, 8vw, 4.5rem);
				line-height: 1.1;
				margin-bottom: 2.5rem;
				font-weight: 800;
				letter-spacing: -0.04em;
				animation: float 6s ease-in-out infinite;
			}

			.title-gradient {
				background: linear-gradient(135deg, #fff 0%, var(--aurora-green) 30%, var(--aurora-cyan) 60%, var(--aurora-blue) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				filter: drop-shadow(0 0 40px rgba(57, 255, 20, 0.2));
			}

			.hero-description {
				font-size: 1.15rem;
				color: var(--text-secondary);
				line-height: 1.8;
				margin-bottom: 4rem;
				max-width: 650px;
				border-left: 2px solid rgba(255, 0, 110, 0.2);
				padding-left: 1.5rem;
			}

			.hero-actions {
				display: flex;
				gap: 1.5rem;
			}

			/* 按钮样式增强 */
			.btn {
				padding: 0.8rem 2rem;
				border-radius: var(--radius-sm);
				font-weight: 600;
				font-size: 0.95rem;
				transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				text-decoration: none;
				position: relative;
				overflow: hidden;
			}

			.btn::before {
				content: '';
				position: absolute;
				top: 0; left: -100%; width: 100%; height: 100%;
				background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
				transition: 0.5s;
			}

			.btn:hover::before { left: 100%; }

			/* 主按钮 - 极光渐变 */
			.btn:first-child {
				background: linear-gradient(135deg, var(--aurora-green), var(--aurora-cyan));
				color: #000;
				box-shadow: 0 0 25px rgba(57, 255, 20, 0.3);
				border: none;
			}

			.btn:first-child:hover {
				transform: translateY(-3px);
				box-shadow: 0 0 40px rgba(57, 255, 20, 0.5), 0 0 60px rgba(0, 245, 212, 0.3);
			}

			/* 次按钮 - 紫色边框 */
			.btn-secondary {
				background: rgba(155, 93, 229, 0.05);
				color: #fff;
				border: 1px solid rgba(155, 93, 229, 0.3);
			}

			.btn-secondary:hover {
				background: rgba(155, 93, 229, 0.1);
				border-color: var(--aurora-purple);
				box-shadow: 0 0 20px rgba(155, 93, 229, 0.3);
				transform: translateY(-3px);
			}

			/* Section Containers */
			.section-container {
				max-width: 1100px;
				margin: 0 auto;
				padding: 8rem 1.5rem;
			}

			/* 滚动触发动画基础类 */
			.reveal {
				opacity: 0;
				transform: translateY(30px);
				transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.reveal.active {
				opacity: 1;
				transform: translateY(0);
			}

			/* 交错动画延迟 */
			.stagger-1 { transition-delay: 0.1s; }
			.stagger-2 { transition-delay: 0.2s; }
			.stagger-3 { transition-delay: 0.3s; }
			.stagger-4 { transition-delay: 0.4s; }

			/* 粒子画布 */
			#particle-canvas {
				position: absolute;
				inset: 0;
				z-index: 1;
				pointer-events: none;
			}

			/* 磁吸按钮 */
			.magnetic-btn {
				transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
			}

			/* 打字机效果 */
			.typewriter-container {
				font-size: 1.15rem;
				color: var(--text-secondary);
				line-height: 1.8;
				margin-bottom: 4rem;
				max-width: 650px;
				border-left: 2px solid rgba(0, 243, 255, 0.1);
				padding-left: 1.5rem;
				font-family: 'Cascadia Code', monospace;
				min-height: 3.5em;
			}

			.typewriter-text {
				display: inline;
			}

			.typewriter-cursor {
				display: inline-block;
				width: 2px;
				height: 1.2em;
				background-color: var(--aurora-green);
				margin-left: 2px;
				vertical-align: middle;
				animation: cursorBlink 1s step-end infinite;
				box-shadow: 0 0 8px var(--aurora-green);
			}

			.typewriter-cursor.typing {
				animation: none;
			}

			@keyframes cursorBlink {
				0%, 50% { opacity: 1; }
				51%, 100% { opacity: 0; }
			}

			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				margin-bottom: 4rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding-bottom: 1rem;
			}

			.section-title {
				font-size: 1.4rem;
				font-family: 'Cascadia Code', monospace;
				font-weight: 700;
				color: var(--text-primary);
				display: flex;
				align-items: center;
				gap: 1.2rem;
				margin: 0;
				border: none; /* 覆盖全局样式 */
				padding: 0;
			}

			.section-title::before {
				content: '//';
				background: linear-gradient(135deg, var(--aurora-green), var(--aurora-cyan));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				font-size: 1.2rem;
				opacity: 0.9;
			}

			/* 文章列表卡片：极致玻璃质感 */
			.post-item {
				display: grid;
				grid-template-columns: 140px 1fr;
				gap: 3rem;
				padding: 2.5rem;
				margin-bottom: 2rem;
				background: rgba(255, 255, 255, 0.01);
				border: 1px solid rgba(255, 255, 255, 0.03);
				border-radius: var(--radius-md);
				transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
				text-decoration: none;
				position: relative;
				backdrop-filter: blur(5px);
			}

			.post-item::after {
				content: '';
				position: absolute;
				inset: 0;
				border-radius: inherit;
				background: radial-gradient(circle at var(--x, 50%) var(--y, 50%), rgba(57, 255, 20, 0.12), transparent 45%);
				opacity: 0;
				transition: opacity 0.3s;
				pointer-events: none;
			}

			.post-item:hover {
				background: rgba(255, 255, 255, 0.03);
				border-color: rgba(57, 255, 20, 0.25);
				transform: scale(1.02) translateX(5px);
				box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4), 0 0 30px rgba(57, 255, 20, 0.1);
			}

			.post-item:hover::after { opacity: 1; }

			.post-date {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-muted);
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
			}

			.post-title {
				font-size: 1.6rem;
				color: var(--text-primary);
				margin-bottom: 1rem;
				font-weight: 700;
				transition: var(--transition-base);
			}

			.post-item:hover .post-title { color: var(--aurora-green); }

			.post-description {
				font-size: 1rem;
				color: var(--text-secondary);
				line-height: 1.6;
				margin: 0;
			}

			/* 专业领域展示 */
			.expertise-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2.5rem;
			}

			.expertise-card {
				padding: 3rem;
				background: rgba(255, 255, 255, 0.015);
				border: 1px solid rgba(255, 255, 255, 0.04);
				border-radius: var(--radius-lg);
				transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
				position: relative;
				overflow: hidden;
			}

			.expertise-card::before {
				content: '';
				position: absolute;
				top: 0; left: 0; width: 100%; height: 4px;
				background: var(--accent-color, var(--primary-cyan));
				opacity: 0.3;
			}

			.expertise-card:hover {
				transform: translateY(-10px);
				background: rgba(255, 255, 255, 0.04);
				border-color: var(--accent-color, var(--neon-cyan));
				box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), 0 0 40px var(--glow-color, rgba(0, 243, 255, 0.15));
			}

			.expertise-card.ebpf { --accent-color: var(--aurora-green); --glow-color: rgba(57, 255, 20, 0.2); }
			.expertise-card.network { --accent-color: var(--aurora-cyan); --glow-color: rgba(0, 245, 212, 0.2); }
			.expertise-card.io { --accent-color: var(--aurora-blue); --glow-color: rgba(0, 187, 249, 0.2); }

			.expertise-icon {
				font-size: 0.75rem;
				font-family: 'Cascadia Code', monospace;
				color: var(--accent-color);
				margin-bottom: 2rem;
				display: block;
				letter-spacing: 0.1em;
			}

			.expertise-title { 
				font-size: 1.75rem; 
				margin-bottom: 1.5rem;
				font-weight: 800;
			}

			.expertise-bar {
				width: 50px; height: 3px;
				margin-bottom: 2rem;
				background: var(--accent-color);
				box-shadow: 0 0 10px var(--accent-color);
			}

			@media (max-width: 768px) {
				.hero { padding: 8rem 0 4rem; }
				.hero-title { font-size: 2.8rem; }
				.post-item { grid-template-columns: 1fr; gap: 1rem; padding: 2rem; }
				.hero-actions { flex-direction: column; }
				.section-container { padding: 4rem 1.5rem; }
			}
		</style>
	</head>
	<body>
		<div class="noise-overlay"></div>
		<Header />
		
		<main>
			<section class="hero">
				<canvas id="particle-canvas"></canvas>
				<div class="hero-container">
					<div class="hero-content">
						<span class="hero-subtitle">CONNECTED // KERNEL_SPACE</span>
						<h1 class="hero-title">
							<span class="title-gradient">Tracing the Kernel,<br>One Syscall at a Time.</span>
						</h1>
						<div class="typewriter-container">
							<span class="typewriter-prefix" style="color: var(--primary-cyan); opacity: 0.7;">$ </span>
							<span class="typewriter-text"></span>
							<span class="typewriter-cursor"></span>
						</div>
						<div class="hero-actions">
							<a href="/blog" class="btn magnetic-btn">读取文章库</a>
							<a href="/about" class="btn btn-secondary magnetic-btn">核心配置</a>
						</div>
					</div>
				</div>
			</section>

			<section class="section-container reveal">
				<div class="section-header">
					<h2 class="section-title">RECENT_LOGS</h2>
					<a href="/blog" style="font-size: 0.85rem; color: var(--primary-cyan); font-family: 'Cascadia Code'; font-weight: 600;">VIEW_ALL_POSTS -></a>
				</div>
				<div class="posts-list">
					{posts.map((post, index) => (
						<a href={`/blog/${post.id}/`} class={`post-item reveal stagger-${Math.min(index + 1, 4)}`}>
							<div class="post-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div class="post-content">
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-description">{post.data.description || 'No metadata provided.'}</p>
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="section-container reveal">
				<div class="section-header">
					<h2 class="section-title">EXPERTISE_DOMAINS</h2>
				</div>
				<div class="expertise-grid">
					<div class="expertise-card ebpf reveal stagger-1">
						<span class="expertise-icon">PATH: /sys/kernel/debug/tracing</span>
						<div class="expertise-bar"></div>
						<h3 class="expertise-title">eBPF & Tracing</h3>
						<p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">内核级观测与 XDP 高性能处理。通过代码直接与内核对话。</p>
					</div>
					<div class="expertise-card network reveal stagger-2">
						<span class="expertise-icon">PATH: /dev/infiniband/uverbs</span>
						<div class="expertise-bar"></div>
						<h3 class="expertise-title">Kernel Network</h3>
						<p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">深入 RDMA、DPDK 等用户态协议栈，挑战数据包吞吐的极限。</p>
					</div>
					<div class="expertise-card io reveal stagger-3">
						<span class="expertise-icon">PATH: /include/linux/io_uring.h</span>
						<div class="expertise-bar"></div>
						<h3 class="expertise-title">Async I/O</h3>
						<p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6;">专注 io_uring、异步协程调度与高性能并发模型的设计与实现。</p>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// 简单的鼠标跟随光效
			const items = document.querySelectorAll('.post-item');
			items.forEach(item => {
				item.addEventListener('mousemove', (e) => {
					const rect = item.getBoundingClientRect();
					const x = ((e.clientX - rect.left) / rect.width) * 100;
					const y = ((e.clientY - rect.top) / rect.height) * 100;
					item.style.setProperty('--x', `${x}%`);
					item.style.setProperty('--y', `${y}%`);
				});
			});

			// ===== 粒子网络背景动画 =====
			const canvas = document.getElementById('particle-canvas');
			const ctx = canvas.getContext('2d');
			let particles = [];
			let mouse = { x: null, y: null, radius: 150 };
			let animationId = null;
			let isActive = true;

			function resizeCanvas() {
				const hero = document.querySelector('.hero');
				if (hero) {
					canvas.width = hero.offsetWidth;
					canvas.height = hero.offsetHeight;
				}
			}

			// 极光之夜色系
			const neonColors = [
				{ r: 57, g: 255, b: 20 },    // 极光绿
				{ r: 0, g: 245, b: 212 },    // 冰蓝
				{ r: 0, g: 187, b: 249 },    // 天蓝
				{ r: 155, g: 93, b: 229 }    // 极光紫
			];

			class Particle {
				constructor() {
					this.x = Math.random() * canvas.width;
					this.y = Math.random() * canvas.height;
					this.vx = (Math.random() - 0.5) * 0.5;
					this.vy = (Math.random() - 0.5) * 0.5;
					this.size = Math.random() * 2 + 1;
					this.baseX = this.x;
					this.baseY = this.y;
					this.color = neonColors[Math.floor(Math.random() * neonColors.length)];
				}

				update() {
					// 基础移动
					this.x += this.vx;
					this.y += this.vy;

					// 边界检测
					if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
					if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

					// 鼠标交互
					if (mouse.x != null) {
						let dx = mouse.x - this.x;
						let dy = mouse.y - this.y;
						let distance = Math.sqrt(dx * dx + dy * dy);
						if (distance < mouse.radius) {
							const force = (mouse.radius - distance) / mouse.radius;
							const directionX = dx / distance;
							const directionY = dy / distance;
							this.x -= directionX * force * 2;
							this.y -= directionY * force * 2;
						}
					}
				}

				draw() {
					ctx.beginPath();
					ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
					ctx.fillStyle = `rgba(${this.color.r}, ${this.color.g}, ${this.color.b}, 0.5)`;
					ctx.fill();
				}
			}

			function initParticles() {
				particles = [];
				const particleCount = Math.min(60, Math.floor((canvas.width * canvas.height) / 15000));
				for (let i = 0; i < particleCount; i++) {
					particles.push(new Particle());
				}
			}

			function connectParticles() {
				const maxDistance = 120;
				for (let i = 0; i < particles.length; i++) {
					for (let j = i + 1; j < particles.length; j++) {
						let dx = particles[i].x - particles[j].x;
						let dy = particles[i].y - particles[j].y;
						let distance = Math.sqrt(dx * dx + dy * dy);

						if (distance < maxDistance) {
							const opacity = (1 - distance / maxDistance) * 0.25;
							// 混合两个粒子的颜色
							const c1 = particles[i].color;
							const c2 = particles[j].color;
							const r = Math.round((c1.r + c2.r) / 2);
							const g = Math.round((c1.g + c2.g) / 2);
							const b = Math.round((c1.b + c2.b) / 2);
							ctx.beginPath();
							ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${opacity})`;
							ctx.lineWidth = 1;
							ctx.moveTo(particles[i].x, particles[i].y);
							ctx.lineTo(particles[j].x, particles[j].y);
							ctx.stroke();
						}
					}
				}
			}

			function animateParticles() {
				if (!isActive) return;
				ctx.clearRect(0, 0, canvas.width, canvas.height);

				particles.forEach(particle => {
					particle.update();
					particle.draw();
				});

				connectParticles();
				animationId = requestAnimationFrame(animateParticles);
			}

			// 鼠标事件
			const hero = document.querySelector('.hero');
			hero.addEventListener('mousemove', (e) => {
				const rect = hero.getBoundingClientRect();
				mouse.x = e.clientX - rect.left;
				mouse.y = e.clientY - rect.top;
			});

			hero.addEventListener('mouseleave', () => {
				mouse.x = null;
				mouse.y = null;
			});

			// 初始化
			resizeCanvas();
			initParticles();
			animateParticles();

			window.addEventListener('resize', () => {
				resizeCanvas();
				initParticles();
			});

			// 页面可见性控制
			document.addEventListener('visibilitychange', () => {
				isActive = document.visibilityState === 'visible';
				if (isActive && !animationId) animateParticles();
			});

			// ===== 滚动触发动画 =====
			const revealElements = document.querySelectorAll('.reveal');

			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');
						revealObserver.unobserve(entry.target);
					}
				});
			}, {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			});

			revealElements.forEach(el => revealObserver.observe(el));

			// ===== 磁吸按钮效果 =====
			const magneticBtns = document.querySelectorAll('.magnetic-btn');

			magneticBtns.forEach(btn => {
				btn.addEventListener('mousemove', (e) => {
					const rect = btn.getBoundingClientRect();
					const x = e.clientX - rect.left - rect.width / 2;
					const y = e.clientY - rect.top - rect.height / 2;

					btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
				});

				btn.addEventListener('mouseleave', () => {
					btn.style.transform = 'translate(0, 0)';
				});
			});

			// ===== 打字机效果 =====
			const typewriterText = document.querySelector('.typewriter-text');
			const typewriterCursor = document.querySelector('.typewriter-cursor');

			const textArray = [
				'专注于 Linux 内核观测、高性能网络协议栈与系统底层调优。',
				'Researching eBPF, RDMA, io_uring...',
				'Tracing the Kernel, One Syscall at a Time.',
				'探索底层极限，记录技术攻坚。'
			];

			let textIndex = 0;
			let charIndex = 0;
			let isDeleting = false;
			let isWaiting = false;

			function typeWriter() {
				const currentText = textArray[textIndex];

				if (isWaiting) {
					setTimeout(typeWriter, 2000);
					isWaiting = false;
					return;
				}

				if (isDeleting) {
					typewriterText.textContent = currentText.substring(0, charIndex - 1);
					charIndex--;
					typewriterCursor.classList.add('typing');
				} else {
					typewriterText.textContent = currentText.substring(0, charIndex + 1);
					charIndex++;
					typewriterCursor.classList.add('typing');
				}

				let typeSpeed = isDeleting ? 30 : 80;

				if (!isDeleting && charIndex === currentText.length) {
					typeSpeed = 2000;
					isWaiting = true;
					isDeleting = true;
					typewriterCursor.classList.remove('typing');
				} else if (isDeleting && charIndex === 0) {
					isDeleting = false;
					textIndex = (textIndex + 1) % textArray.length;
					typeSpeed = 500;
					typewriterCursor.classList.remove('typing');
				}

				setTimeout(typeWriter, typeSpeed);
			}

			// 延迟启动打字机效果
			setTimeout(typeWriter, 1000);
		</script>
	</body>
</html>
---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 4);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* ===== 液态金属配色系统 ===== */
			:root {
				--liquid-bg: #0f0d1a;
				--liquid-purple: #6366f1;
				--liquid-pink: #ec4899;
				--liquid-cyan: #06b6d4;
				--liquid-amber: #f59e0b;
				--glass-bg: rgba(255, 255, 255, 0.03);
				--glass-border: rgba(255, 255, 255, 0.08);
				--text-primary: #f8fafc;
				--text-secondary: #94a3b8;
				--text-muted: #64748b;
			}

			/* 全局动画定义 */
			@keyframes float {
				0%, 100% { transform: translateY(0px); }
				50% { transform: translateY(-10px); }
			}

			@keyframes pulse-glow {
				0%, 100% { opacity: 0.4; }
				50% { opacity: 0.8; }
			}

			@keyframes breathe {
				0%, 100% { transform: scale(1); opacity: 0.6; }
				50% { transform: scale(1.05); opacity: 1; }
			}

			@keyframes gradient-shift {
				0% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
				100% { background-position: 0% 50%; }
			}

			/* 噪点覆盖 */
			.noise-overlay {
				position: fixed;
				inset: 0;
				z-index: 9999;
				pointer-events: none;
				opacity: 0.03;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
			}

			/* Hero Section - 全屏沉浸 */
			.hero {
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				position: relative;
				overflow: hidden;
				background: var(--liquid-bg);
			}

			/* 流体Canvas背景 */
			#fluid-canvas {
				position: absolute;
				inset: 0;
				z-index: 0;
				will-change: transform, opacity;
			}

			.hero-content {
				max-width: 1000px;
				margin: 0 auto;
				padding: 2rem;
				text-align: center;
				position: relative;
				z-index: 10;
				will-change: transform, opacity;
			}

			/* 渐变叠加层 */
			.hero::after {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(ellipse at 50% 50%, transparent 0%, var(--liquid-bg) 70%);
				z-index: 1;
				pointer-events: none;
			}

			/* 故障艺术解码标题 - 增强对比度 */
			.hero-subtitle {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: #22d3ee;
				letter-spacing: 0.4em;
				text-transform: uppercase;
				margin-bottom: 2rem;
				opacity: 0;
				animation: fadeIn 1s ease forwards 0.5s;
				text-shadow:
					0 0 10px rgba(34, 211, 238, 0.5),
					0 0 20px rgba(34, 211, 238, 0.3),
					0 0 40px rgba(34, 211, 238, 0.1);
			}

			@keyframes fadeIn {
				to { opacity: 1; }
			}

			.hero-title {
				font-size: clamp(3rem, 10vw, 6rem);
				font-weight: 800;
				line-height: 1.1;
				margin-bottom: 2rem;
				position: relative;
			}

			.hero-title .char {
				display: inline-block;
				background: linear-gradient(135deg, var(--text-primary) 0%, var(--liquid-purple) 50%, var(--liquid-pink) 100%);
				background-size: 200% 200%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				opacity: 0;
				transform: translateY(20px) scale(0.9);
				filter: blur(10px);
			}

			.hero-title .char.decoded {
				opacity: 1;
				transform: translateY(0) scale(1);
				filter: blur(0);
				transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
				text-shadow:
					0 0 20px rgba(99, 102, 241, 0.3),
					0 0 40px rgba(99, 102, 241, 0.1);
				-webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
			}

			/* 故障效果 */
			.hero-title .char.glitch {
				animation: glitch 0.3s ease;
			}

			@keyframes glitch {
				0%, 100% { transform: translate(0); }
				20% { transform: translate(-2px, 2px); }
				40% { transform: translate(2px, -2px); }
				60% { transform: translate(-2px, -2px); }
				80% { transform: translate(2px, 2px); }
			}

			/* 玻璃拟态描述卡片 - 增强对比度 */
			.hero-description {
				max-width: 600px;
				margin: 0 auto 3rem;
				padding: 1.5rem 2rem;
				background: rgba(15, 13, 26, 0.7);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				border: 1px solid rgba(99, 102, 241, 0.2);
				border-radius: 24px;
				position: relative;
				overflow: hidden;
				box-shadow:
					0 8px 32px rgba(0, 0, 0, 0.4),
					inset 0 1px 0 rgba(255, 255, 255, 0.05);
			}

			.hero-description::before {
				content: '';
				position: absolute;
				top: 0;
				left: -100%;
				width: 100%;
				height: 100%;
				background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
				transition: left 0.5s;
			}

			.hero-description:hover::before {
				left: 100%;
			}

			.hero-description p {
				margin: 0;
				font-size: 1.15rem;
				color: #e2e8f0;
				line-height: 1.8;
				text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
			}

			/* 磁吸按钮组 */
			.hero-actions {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
				perspective: 1000px;
			}

			.magnetic-btn {
				position: relative;
				padding: 1rem 2.5rem;
				font-size: 0.95rem;
				font-weight: 600;
				border-radius: 16px;
				text-decoration: none;
				transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s;
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				cursor: pointer;
				border: none;
				overflow: hidden;
			}

			.magnetic-btn-primary {
				background: linear-gradient(135deg, var(--liquid-purple), var(--liquid-pink));
				color: white;
				box-shadow: 0 10px 40px rgba(99, 102, 241, 0.3);
			}

			.magnetic-btn-primary:hover {
				box-shadow: 0 15px 50px rgba(99, 102, 241, 0.5), 0 0 30px rgba(236, 72, 153, 0.3);
			}

			.magnetic-btn-secondary {
				background: var(--glass-bg);
				backdrop-filter: blur(10px);
				border: 1px solid var(--glass-border);
				color: var(--text-primary);
			}

			.magnetic-btn-secondary:hover {
				background: rgba(255, 255, 255, 0.05);
				border-color: var(--liquid-purple);
				box-shadow: 0 0 30px rgba(99, 102, 241, 0.2);
			}

			/* 向下滚动指示 */
			.scroll-indicator {
				position: absolute;
				bottom: 3rem;
				left: 50%;
				transform: translateX(-50%);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5rem;
				color: var(--text-muted);
				font-size: 0.75rem;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				z-index: 10;
				animation: breathe 2s ease-in-out infinite;
			}

			.scroll-indicator svg {
				width: 24px;
				height: 24px;
				animation: float 2s ease-in-out infinite;
			}

			/* 内容区块 */
			.section {
				padding: 8rem 1.5rem;
				position: relative;
			}

			.section-container {
				max-width: 1100px;
				margin: 0 auto;
			}

			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				margin-bottom: 4rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid var(--glass-border);
			}

			.section-title {
				font-size: 1.4rem;
				font-weight: 700;
				display: flex;
				align-items: center;
				gap: 1rem;
				margin: 0;
			}

			.section-title::before {
				content: '';
				display: inline-block;
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--liquid-purple), var(--liquid-pink));
				box-shadow: 0 0 15px var(--liquid-purple);
			}

			/* 3D 倾斜卡片 */
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
				gap: 2rem;
				perspective: 2000px;
			}

			.tilt-card {
				background: var(--glass-bg);
				backdrop-filter: blur(20px);
				border: 1px solid var(--glass-border);
				border-radius: 20px;
				padding: 2rem;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				gap: 1rem;
				transition: transform 0.1s ease-out, box-shadow 0.3s;
				transform-style: preserve-3d;
				position: relative;
				overflow: hidden;
			}

			.tilt-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(99, 102, 241, 0.15), transparent 50%);
				opacity: 0;
				transition: opacity 0.3s;
			}

			.tilt-card:hover::before {
				opacity: 1;
			}

			.tilt-card:hover {
				box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3), 0 0 30px rgba(99, 102, 241, 0.1);
			}

			.post-date {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.8rem;
				color: var(--liquid-cyan);
				opacity: 0.8;
			}

			.post-title {
				font-size: 1.3rem;
				font-weight: 700;
				color: var(--text-primary);
				transition: color 0.3s;
			}

			.tilt-card:hover .post-title {
				color: var(--liquid-purple);
			}

			.post-description {
				font-size: 0.95rem;
				color: var(--text-secondary);
				line-height: 1.6;
				margin: 0;
			}

			/* 技能气泡 */
			.skills-bubbles {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				justify-content: center;
			}

			.skill-bubble {
				padding: 0.75rem 1.5rem;
				background: var(--glass-bg);
				border: 1px solid var(--glass-border);
				border-radius: 100px;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-secondary);
				transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
				cursor: default;
			}

			.skill-bubble:hover {
				transform: translateY(-3px) scale(1.05);
				background: rgba(99, 102, 241, 0.1);
				border-color: var(--liquid-purple);
				color: var(--liquid-purple);
				box-shadow: 0 10px 30px rgba(99, 102, 241, 0.2);
			}

			/* 环境光晕层 - 修复版 */
			.ambient-glow {
				position: absolute;
				inset: 0;
				background:
					radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.15) 0%, transparent 70%),
					radial-gradient(ellipse 60% 40% at 80% 60%, rgba(236, 72, 153, 0.08) 0%, transparent 60%);
				z-index: 0;
				pointer-events: none;
			}

			/* 网格背景纹理 */
			.section::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
				background-size: 50px 50px;
				pointer-events: none;
				z-index: 0;
			}

			@media (max-width: 768px) {
				.hero { padding: 6rem 1rem; }
				.hero-actions { flex-direction: column; align-items: center; }
				.posts-grid { grid-template-columns: 1fr; }
				.section { padding: 4rem 1rem; }
			}
		</style>
	</head>
	<body>
		<div class="noise-overlay"></div>
		<Header />

		<main>
			<!-- Hero Section -->
			<section class="hero">
				<canvas id="fluid-canvas"></canvas>
				<div class="hero-content">
					<span class="hero-subtitle">System.kernel_space // Developer</span>
					<h1 class="hero-title" data-text="Schatten's Lab">Schatten's Lab</h1>
					<div class="hero-description">
						<p>底层技术探索者。专注于 Linux 高性能网络与系统编程。在这里记录技术攻坚，分享代码美学。</p>
					</div>
					<div class="hero-actions">
						<a href="/blog" class="magnetic-btn magnetic-btn-primary">
							探索文章
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<line x1="5" y1="12" x2="19" y2="12"></line>
								<polyline points="12 5 19 12 12 19"></polyline>
							</svg>
						</a>
						<a href="/about" class="magnetic-btn magnetic-btn-secondary">
							关于我
						</a>
					</div>
				</div>
				<div class="scroll-indicator">
					<span>Scroll</span>
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M12 5v14M19 12l-7 7-7-7"/>
					</svg>
				</div>
			</section>

			<!-- 最近文章 -->
			<section class="section">
				<div class="ambient-glow"></div>
				<div class="section-container" style="position: relative; z-index: 1;">
					<div class="section-header">
						<h2 class="section-title">最新日志</h2>
						<a href="/blog" style="font-size: 0.9rem; color: var(--liquid-purple); text-decoration: none;">查看全部 →</a>
					</div>
					<div class="posts-grid">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="tilt-card" data-tilt>
								<div class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-description">{post.data.description || '暂无描述'}</p>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- 技术领域 -->
			<section class="section" style="background: rgba(0,0,0,0.2);">
				<div class="section-container">
					<div class="section-header">
						<h2 class="section-title">技术领域</h2>
					</div>
					<div class="skills-bubbles">
						<span class="skill-bubble">eBPF / 内核追踪</span>
						<span class="skill-bubble">RDMA / 高性能网络</span>
						<span class="skill-bubble">io_uring / 异步 I/O</span>
						<span class="skill-bubble">XDP / 数据包处理</span>
						<span class="skill-bubble">DPDK / 用户态网络</span>
						<span class="skill-bubble">性能调优</span>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// ===== 流体Canvas背景 =====
			const canvas = document.getElementById('fluid-canvas') as HTMLCanvasElement;
			const ctx = canvas.getContext('2d')!;
			let width: number, height: number;
			let particles: FluidParticle[] = [];
			let mouse = { x: 0, y: 0, active: false, timer: 0 as unknown as ReturnType<typeof setTimeout> };
			let animationId: number;

			// 配色
			const colors = [
				{ r: 99, g: 102, b: 241 },   // 紫色
				{ r: 236, g: 72, b: 153 },   // 粉色
				{ r: 6, g: 182, b: 212 },    // 青色
				{ r: 245, g: 158, b: 11 }    // 琥珀
			];

			function resize() {
				width = canvas.width = window.innerWidth;
				height = canvas.height = window.innerHeight;
			}

			class FluidParticle {
				x!: number;
				y!: number;
				vx!: number;
				vy!: number;
				radius!: number;
				color!: { r: number; g: number; b: number };
				opacity!: number;
				phase!: number;

				constructor() {
					this.reset();
				}

				reset() {
					this.x = Math.random() * width;
					this.y = Math.random() * height;
					this.vx = (Math.random() - 0.5) * 0.5;
					this.vy = (Math.random() - 0.5) * 0.5;
					this.radius = Math.random() * 150 + 100;
					this.color = colors[Math.floor(Math.random() * colors.length)];
					this.opacity = Math.random() * 0.3 + 0.1;
					this.phase = Math.random() * Math.PI * 2;
				}

				update() {
					// 基础流动
					this.x += this.vx;
					this.y += this.vy;
					this.phase += 0.01;

					// 波动
					this.x += Math.sin(this.phase) * 0.5;
					this.y += Math.cos(this.phase * 0.7) * 0.3;

					// 边界循环
					if (this.x < -this.radius) this.x = width + this.radius;
					if (this.x > width + this.radius) this.x = -this.radius;
					if (this.y < -this.radius) this.y = height + this.radius;
					if (this.y > height + this.radius) this.y = -this.radius;

					// 鼠标交互 - 涟漪效果
					if (mouse.active) {
						const dx = mouse.x - this.x;
						const dy = mouse.y - this.y;
						const dist = Math.sqrt(dx * dx + dy * dy);

						if (dist < 300) {
							const force = (300 - dist) / 300;
							this.x -= dx * force * 0.02;
							this.y -= dy * force * 0.02;
						}
					}
				}

				draw() {
					const gradient = ctx.createRadialGradient(
						this.x, this.y, 0,
						this.x, this.y, this.radius
					);

					gradient.addColorStop(0, `rgba(${this.color.r}, ${this.color.g}, ${this.color.b}, ${this.opacity})`);
					gradient.addColorStop(0.5, `rgba(${this.color.r}, ${this.color.g}, ${this.color.b}, ${this.opacity * 0.5})`);
					gradient.addColorStop(1, 'transparent');

					ctx.fillStyle = gradient;
					ctx.beginPath();
					ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
					ctx.fill();
				}
			}

			function initParticles() {
				particles = [];
				const count = Math.min(25, Math.floor((width * height) / 40000));
				for (let i = 0; i < count; i++) {
					particles.push(new FluidParticle());
				}
			}

			function animate() {
				// 使用半透明清除产生拖尾效果
				ctx.fillStyle = 'rgba(15, 13, 26, 0.1)';
				ctx.fillRect(0, 0, width, height);

				// 使用 lighter 混合模式创造发光效果
				ctx.globalCompositeOperation = 'lighter';

				particles.forEach(p => {
					p.update();
					p.draw();
				});

				ctx.globalCompositeOperation = 'source-over';

				animationId = requestAnimationFrame(animate);
			}

			// 鼠标事件
			window.addEventListener('mousemove', (e: MouseEvent) => {
				mouse.x = e.clientX;
				mouse.y = e.clientY;
				mouse.active = true;

				clearTimeout(mouse.timer);
				mouse.timer = setTimeout(() => {
					mouse.active = false;
				}, 100);
			});

			window.addEventListener('resize', () => {
				resize();
				initParticles();
			});

			// 初始化
			resize();
			initParticles();
			animate();

			// 页面可见性控制
			document.addEventListener('visibilitychange', () => {
				if (document.visibilityState === 'hidden') {
					cancelAnimationFrame(animationId);
				} else {
					animate();
				}
			});

			// ===== 故障艺术解码动画 =====
			const title = document.querySelector('.hero-title') as HTMLElement | null;
			if (title) {
			const text = title.dataset.text!;
			const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';

			title.innerHTML = text.split('').map((char: string, i: number) => {
				if (char === ' ') return '<span class="char">&nbsp;</span>';
				return `<span class="char" data-char="${char}" data-index="${i}">${char}</span>`;
			}).join('');

			const charElements = title.querySelectorAll('.char');

			// 依次解码每个字符
			charElements.forEach((char: Element, index: number) => {
				const el = char as HTMLElement;
				const targetChar = el.dataset.char!;
				let iterations = 0;
				const maxIterations = 8 + Math.random() * 5;
				const delay = 800 + index * 80;

				setTimeout(() => {
					const interval = setInterval(() => {
						if (iterations >= maxIterations) {
							el.textContent = targetChar;
							el.classList.add('decoded');
							// 随机添加故障效果
							if (Math.random() > 0.7) {
								el.classList.add('glitch');
								setTimeout(() => el.classList.remove('glitch'), 300);
							}
							clearInterval(interval);
						} else {
							el.textContent = chars[Math.floor(Math.random() * chars.length)];
							iterations++;
						}
					}, 50);
				}, delay);
			});
			}

			// ===== 3D 倾斜卡片 =====
			const tiltCards = document.querySelectorAll('.tilt-card');

			tiltCards.forEach((card: Element) => {
				const el = card as HTMLElement;
				el.addEventListener('mousemove', (e: MouseEvent) => {
					const rect = el.getBoundingClientRect();
					const x = e.clientX - rect.left;
					const y = e.clientY - rect.top;
					const centerX = rect.width / 2;
					const centerY = rect.height / 2;

					const rotateX = (y - centerY) / 20;
					const rotateY = (centerX - x) / 20;

					el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
					el.style.setProperty('--mouse-x', `${(x / rect.width) * 100}%`);
					el.style.setProperty('--mouse-y', `${(y / rect.height) * 100}%`);
				});

				el.addEventListener('mouseleave', () => {
					el.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
				});
			});

			// ===== 磁吸按钮 =====
			const magneticBtns = document.querySelectorAll('.magnetic-btn');

			magneticBtns.forEach((btn: Element) => {
				const el = btn as HTMLElement;
				el.addEventListener('mousemove', (e: MouseEvent) => {
					const rect = el.getBoundingClientRect();
					const x = e.clientX - rect.left - rect.width / 2;
					const y = e.clientY - rect.top - rect.height / 2;

					el.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
				});

				el.addEventListener('mouseleave', () => {
					el.style.transform = 'translate(0, 0)';
				});
			});

			// ===== 视差滚动效果 =====
			const parallaxCanvas = document.getElementById('fluid-canvas') as HTMLElement;
			const ambientGlow = document.querySelector('.ambient-glow') as HTMLElement;
			const heroContent = document.querySelector('.hero-content') as HTMLElement;

			window.addEventListener('scroll', () => {
				const scrolled = window.scrollY;
				const viewportHeight = window.innerHeight;

				// Hero Canvas 视差 - 向上滚动时缓慢移动并淡出
				if (parallaxCanvas && scrolled < viewportHeight) {
					const canvasSpeed = 0.4;
					parallaxCanvas.style.transform = `translateY(${scrolled * canvasSpeed}px)`;
					parallaxCanvas.style.opacity = String(1 - (scrolled / viewportHeight) * 0.8);
				}

				// Hero 内容视差 - 比背景移动更快，产生深度感
				if (heroContent && scrolled < viewportHeight) {
					const contentSpeed = 0.7;
					heroContent.style.transform = `translateY(${scrolled * contentSpeed}px)`;
					heroContent.style.opacity = String(1 - (scrolled / (viewportHeight * 0.6)));
				}

				// 环境光晕视差 - 反向缓慢移动
				if (ambientGlow) {
					const glowSpeed = -0.15;
					ambientGlow.style.transform = `translateY(${scrolled * glowSpeed}px)`;
				}
			});

			// ===== 平滑滚动 =====
			const scrollIndicator = document.querySelector('.scroll-indicator');
			const firstSection = document.querySelector('.section');
			if (scrollIndicator && firstSection) {
				scrollIndicator.addEventListener('click', () => {
					firstSection.scrollIntoView({ behavior: 'smooth' });
				});
			}
		</script>
	</body>
</html>
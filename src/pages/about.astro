---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			/* ===== 莫兰迪配色变量 ===== */
			:root {
				--morandi-blue: #6b8cae;
				--morandi-green: #8faa8f;
				--morandi-purple: #a68fac;
				--morandi-warm: #b8a090;
				--morandi-cool: #7a8b99;
				--morandi-bg: #141820;
			}

			.about-container {
				min-height: 100vh;
				background:
					radial-gradient(at 0% 0%, rgba(107, 140, 174, 0.1) 0, transparent 50%),
					radial-gradient(at 100% 100%, rgba(143, 170, 143, 0.08) 0, transparent 50%),
					var(--bg-abyss);
			}

			/* Hero Section */
			.about-hero {
				padding: 10rem 0 6rem;
				position: relative;
				overflow: hidden;
			}

			.hero-content {
				max-width: 900px;
				margin: 0 auto;
				padding: 0 1.5rem;
				text-align: center;
			}

			.hero-subtitle {
				font-family: 'Cascadia Code', monospace;
				color: var(--morandi-cool);
				font-size: 0.85rem;
				letter-spacing: 0.3em;
				margin-bottom: 1.5rem;
				display: block;
			}

			.hero-title {
				font-size: clamp(2.5rem, 6vw, 4rem);
				font-weight: 800;
				margin: 0 0 1.5rem;
				background: linear-gradient(135deg, #e8e8e8 0%, var(--morandi-blue) 60%, var(--morandi-purple) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				filter: drop-shadow(0 0 30px rgba(107, 140, 174, 0.2));
			}

			.hero-description {
				font-size: 1.2rem;
				color: var(--text-secondary);
				max-width: 600px;
				margin: 0 auto;
				line-height: 1.8;
			}

			/* Main Content */
			.about-content {
				max-width: 900px;
				margin: 0 auto;
				padding: 0 1.5rem 8rem;
			}

			/* Section Styling */
			.section {
				margin-bottom: 5rem;
			}

			.section-title {
				font-size: 1.5rem;
				font-weight: 700;
				margin-bottom: 2rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			.section-title::before {
				content: '';
				display: inline-block;
				width: 4px;
				height: 1.2em;
				background: linear-gradient(180deg, var(--morandi-blue), var(--morandi-green));
				border-radius: 2px;
			}

			/* Intro Card */
			.intro-card {
				background: rgba(255, 255, 255, 0.02);
				border: 1px solid rgba(107, 140, 174, 0.1);
				border-radius: var(--radius-lg);
				padding: 2.5rem;
				margin-bottom: 3rem;
				backdrop-filter: blur(10px);
			}

			.intro-text {
				font-size: 1.1rem;
				line-height: 2;
				color: var(--text-secondary);
			}

			.intro-text strong {
				color: var(--morandi-blue);
				font-weight: 600;
			}

			/* Skills Grid */
			.skills-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
			}

			.skill-card {
				background: rgba(255, 255, 255, 0.015);
				border: 1px solid rgba(143, 170, 143, 0.1);
				border-radius: var(--radius-md);
				padding: 1.5rem;
				transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.skill-card:hover {
				transform: translateY(-5px);
				border-color: rgba(143, 170, 143, 0.25);
				box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
			}

			.skill-name {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--morandi-green);
				margin-bottom: 0.5rem;
				letter-spacing: 0.05em;
			}

			.skill-tags {
				font-size: 0.95rem;
				color: var(--text-secondary);
				line-height: 1.6;
			}

			/* Contact Section */
			.contact-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
			}

			.contact-link {
				display: inline-flex;
				align-items: center;
				gap: 0.75rem;
				padding: 1rem 1.5rem;
				background: rgba(107, 140, 174, 0.05);
				border: 1px solid rgba(107, 140, 174, 0.15);
				border-radius: var(--radius-md);
				color: var(--text-secondary);
				text-decoration: none;
				transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.contact-link:hover {
				background: rgba(107, 140, 174, 0.1);
				border-color: var(--morandi-blue);
				color: var(--text-primary);
				transform: translateY(-2px);
			}

			.contact-icon {
				width: 20px;
				height: 20px;
				color: var(--morandi-blue);
			}

			/* Footer Note */
			.footer-note {
				background: linear-gradient(135deg, rgba(107, 140, 174, 0.05), rgba(166, 143, 172, 0.05));
				border: 1px solid rgba(107, 140, 174, 0.1);
				border-radius: var(--radius-lg);
				padding: 2rem;
				text-align: center;
			}

			.footer-note p {
				margin: 0;
				color: var(--text-secondary);
				line-height: 1.8;
			}

			.footer-note strong {
				color: var(--morandi-purple);
			}

			@media (max-width: 768px) {
				.about-hero { padding: 8rem 0 4rem; }
				.hero-title { font-size: 2.2rem; }
				.intro-card { padding: 1.5rem; }
				.skills-grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<div class="about-container">
			<Header />

			<main>
				<section class="about-hero">
					<div class="hero-content">
						<span class="hero-subtitle">WHO_AM_I // DEVELOPER</span>
						<h1 class="hero-title">Schatten</h1>
						<p class="hero-description">
							热爱底层技术的开发者，专注于 Linux 内核与高性能计算
						</p>
					</div>
				</section>

				<div class="about-content">
					<!-- 关于我 -->
					<section class="section">
						<div class="intro-card">
							<p class="intro-text">
								我是 <strong>Schatten</strong>，一名热爱底层技术的开发者。<br><br>
								专注于 <strong>Linux 内核</strong>、<strong>高性能网络</strong> 和 <strong>系统级编程</strong>。
								日常与 eBPF、RDMA、io_uring 打交道，享受从内核视角理解系统的乐趣。
							</p>
						</div>
					</section>

					<!-- 技术领域 -->
					<section class="section">
						<h2 class="section-title">技术领域</h2>
						<div class="skills-grid">
							<div class="skill-card">
								<div class="skill-name">KERNEL_TRACING</div>
								<div class="skill-tags">eBPF、BCC、bpftrace、Ftrace</div>
							</div>
							<div class="skill-card">
								<div class="skill-name">NETWORK_STACK</div>
								<div class="skill-tags">RDMA、DPDK、XDP、内核协议栈</div>
							</div>
							<div class="skill-card">
								<div class="skill-name">ASYNC_IO</div>
								<div class="skill-tags">io_uring、AIO、事件驱动架构</div>
							</div>
							<div class="skill-card">
								<div class="skill-name">PERF_TUNING</div>
								<div class="skill-tags">性能分析、延迟优化、吞吐量调优</div>
							</div>
						</div>
					</section>

					<!-- 联系方式 -->
					<section class="section">
						<h2 class="section-title">联系方式</h2>
						<div class="contact-grid">
							<a href="https://github.com/bitborne" target="_blank" class="contact-link">
								<svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor">
									<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
								</svg>
								GitHub / bitborne
							</a>
							<a href="mailto:3192396192@qq.com" class="contact-link">
								<svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<rect x="2" y="4" width="20" height="16" rx="2"/>
									<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
								</svg>
								3192396192@qq.com
							</a>
						</div>
					</section>

					<!-- 关于本站 -->
					<section class="section">
						<div class="footer-note">
							<p>
								使用 <strong>Astro</strong> 构建 · 主题 <strong>Phycat Abyss</strong><br>
								记录技术探索的轨迹，分享内核世界的奇妙
							</p>
						</div>
					</section>
				</div>
			</main>

			<Footer />
		</div>
	</body>
</html>
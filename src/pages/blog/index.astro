---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getCollection('blog');

// 按第一层文件夹分组
const categoryData = posts.reduce((acc, post) => {
	const parts = post.id.split('/');
	// 如果在根目录，则归类为 'Uncategorized'，否则取第一层目录名
	const folder = parts.length > 1 ? parts[0] : 'Notes';
	if (!acc[folder]) {
		acc[folder] = {
			count: 0,
			latestDate: new Date(0),
		};
	}
	acc[folder].count++;
	const postDate = new Date(post.data.pubDate);
	if (postDate > acc[folder].latestDate) {
		acc[folder].latestDate = postDate;
	}
	return acc;
}, {} as Record<string, { count: number; latestDate: Date }>);

const categories = Object.keys(categoryData).sort();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			/* Header Section */
			.archive-header {
				padding: 8rem 0 4rem;
				background: var(--bg-abyss);
				background-image: 
					linear-gradient(rgba(0, 243, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(0, 243, 255, 0.03) 1px, transparent 1px);
				background-size: 40px 40px;
				border-bottom: 1px solid var(--border-color);
				position: relative;
			}

			.archive-header::after {
				content: '';
				position: absolute;
				bottom: -1px;
				left: 0;
				width: 100%;
				height: 100px;
				background: linear-gradient(to top, var(--bg-abyss), transparent);
			}

			.header-container {
				max-width: 1000px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.header-subtitle {
				font-family: 'Cascadia Code', monospace;
				color: var(--primary-cyan);
				font-size: 0.9rem;
				letter-spacing: 0.2em;
				margin-bottom: 1rem;
				display: block;
			}

			.header-title {
				font-size: 3rem;
				font-weight: 800;
				margin: 0;
				color: var(--text-primary);
			}

			/* Folder Grid */
			.archive-main {
				max-width: 1000px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
			}

			.folder-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
			}

			.folder-card {
				background: var(--bg-surface);
				border: 1px solid var(--border-color);
				border-radius: var(--radius-md);
				padding: 2rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				transition: var(--transition-base);
				text-decoration: none;
				position: relative;
				overflow: hidden;
			}

			.folder-card:hover {
				border-color: var(--primary-cyan);
				transform: translateY(-5px);
				box-shadow: var(--glow-cyan);
			}

			.folder-icon {
				width: 48px;
				height: 48px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(0, 243, 255, 0.05);
				border-radius: var(--radius-sm);
				color: var(--primary-cyan);
			}

			.folder-info h2 {
				font-size: 1.25rem;
				margin-bottom: 0.5rem;
				color: var(--text-primary);
			}

			.folder-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.8rem;
				color: var(--text-muted);
			}

			.post-count {
				color: var(--primary-cyan);
				font-weight: 700;
			}

			.folder-footer {
				margin-top: auto;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.8rem;
				color: var(--text-muted);
				font-family: 'Cascadia Code', monospace;
			}

			.explore-text {
				color: var(--primary-cyan);
				opacity: 0;
				transform: translateX(-10px);
				transition: var(--transition-base);
			}

			.folder-card:hover .explore-text {
				opacity: 1;
				transform: translateX(0);
			}

			@media (max-width: 768px) {
				.header-title { font-size: 2.2rem; }
				.folder-grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />

		<div class="archive-header">
			<div class="header-container">
				<span class="header-subtitle">FILE_SYSTEM / VOL_01</span>
				<h1 class="header-title">Archives.</h1>
			</div>
		</div>

		<main class="archive-main">
			<div class="folder-grid">
				{categories.map(category => (
					<a href={`/blog/category/${category}`} class="folder-card">
						<div class="folder-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
							</svg>
						</div>
						<div class="folder-info">
							<h2>{category}</h2>
							<div class="folder-meta">
								<span>ENTRIES: <span class="post-count">{categoryData[category].count}</span></span>
							</div>
						</div>
						<div class="folder-footer">
							<span>LAST_MOD: {categoryData[category].latestDate.toISOString().split('T')[0]}</span>
							<span class="explore-text">EXPLORE_DIR -></span>
						</div>
					</a>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>
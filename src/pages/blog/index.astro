---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getCollection('blog');

// 按第一层文件夹分组
const categoryData = posts.reduce((acc, post) => {
	const parts = post.id.split('/');
	// 如果在根目录，则归类为 'Notes'，否则取第一层目录名
	const folder = parts.length > 1 ? parts[0] : 'Notes';
	if (!acc[folder]) {
		acc[folder] = {
			count: 0,
			latestDate: new Date(0),
		};
	}
	acc[folder].count++;
	const postDate = new Date(post.data.pubDate);
	if (postDate > acc[folder].latestDate) {
		acc[folder].latestDate = postDate;
	}
	return acc;
}, {} as Record<string, { count: number; latestDate: Date }>);

const categories = Object.keys(categoryData).sort();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`归档 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			@keyframes fadeInScale {
				from { opacity: 0; transform: scale(0.95) translateY(20px); }
				to { opacity: 1; transform: scale(1) translateY(0); }
			}

			@keyframes gridPulse {
				0%, 100% { opacity: 0.3; }
				50% { opacity: 0.6; }
			}

			/* 噪点覆盖 */
			.noise-overlay {
				position: fixed;
				inset: 0;
				z-index: 9999;
				pointer-events: none;
				opacity: 0.04;
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
			}

			/* 粒子画布 */
			#particle-canvas {
				position: absolute;
				inset: 0;
				z-index: 1;
				pointer-events: none;
			}

			/* 滚动触发动画 */
			.reveal {
				opacity: 0;
				transform: translateY(30px) scale(0.95);
				transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.reveal.active {
				opacity: 1;
				transform: translateY(0) scale(1);
			}

			/* 交错延迟 */
			.stagger-1 { transition-delay: 0.1s; }
			.stagger-2 { transition-delay: 0.2s; }
			.stagger-3 { transition-delay: 0.3s; }
			.stagger-4 { transition-delay: 0.4s; }
			.stagger-5 { transition-delay: 0.5s; }
			.stagger-6 { transition-delay: 0.6s; }

			/* Header Section */
			.archive-header {
				padding: 10rem 0 6rem;
				background: var(--bg-abyss);
				position: relative;
				overflow: hidden;
			}

			/* 动态网格背景 */
			.archive-header::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image: 
					linear-gradient(rgba(0, 243, 255, 0.05) 1px, transparent 1px),
					linear-gradient(90deg, rgba(0, 243, 255, 0.05) 1px, transparent 1px);
				background-size: 50px 50px;
				-webkit-mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
				mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
				animation: gridPulse 4s ease-in-out infinite;
			}

			/* 扫描线 */
			.archive-header::after {
				content: '';
				position: absolute;
				top: 0; left: 0; width: 100%; height: 100%;
				background: linear-gradient(to bottom, transparent, rgba(0, 243, 255, 0.05), transparent);
				background-size: 100% 400%;
				animation: scan 10s linear infinite;
				pointer-events: none;
			}

			.header-container {
				max-width: 1100px;
				margin: 0 auto;
				padding: 0 1.5rem;
				position: relative;
				z-index: 2;
			}

			.header-subtitle {
				font-family: 'Cascadia Code', monospace;
				color: var(--primary-cyan);
				font-size: 0.9rem;
				letter-spacing: 0.4em;
				margin-bottom: 1.5rem;
				display: block;
				text-shadow: 0 0 10px rgba(0, 243, 255, 0.5);
			}

			.header-title {
				font-size: 4rem;
				font-weight: 800;
				margin: 0;
				color: var(--text-primary);
				letter-spacing: -0.03em;
				background: linear-gradient(to right, #fff, var(--primary-cyan));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}

			/* Folder Grid */
			.archive-main {
				max-width: 1100px;
				margin: 0 auto;
				padding: 4rem 1.5rem 10rem;
			}

			.folder-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
				gap: 2.5rem;
			}

			.folder-card {
				background: rgba(255, 255, 255, 0.015);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: var(--radius-lg);
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				gap: 2rem;
				transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
				text-decoration: none;
				position: relative;
				overflow: hidden;
				backdrop-filter: blur(10px);
			}

			.folder-card::before {
				content: '';
				position: absolute;
				top: 0; left: 0; width: 100%; height: 2px;
				background: linear-gradient(90deg, transparent, var(--primary-cyan), transparent);
				transform: translateX(-100%);
				transition: 0.5s;
			}

			.folder-card:hover {
				background: rgba(255, 255, 255, 0.03);
				border-color: rgba(0, 243, 255, 0.2);
				transform: translateY(-10px) scale(1.02);
				box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 243, 255, 0.1);
			}

			.folder-card:hover::before {
				transform: translateX(100%);
			}

			.folder-icon {
				width: 56px;
				height: 56px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(0, 243, 255, 0.05);
				border: 1px solid rgba(0, 243, 255, 0.1);
				border-radius: var(--radius-md);
				color: var(--primary-cyan);
				transition: var(--transition-base);
			}

			.folder-card:hover .folder-icon {
				background: var(--primary-cyan);
				color: #000;
				box-shadow: 0 0 20px var(--primary-cyan);
			}

			.folder-info h2 {
				font-size: 1.5rem;
				margin-bottom: 0.8rem;
				color: var(--text-primary);
				font-weight: 700;
			}

			.folder-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-muted);
			}

			.post-count {
				color: var(--primary-cyan);
				font-weight: 700;
			}

			.folder-footer {
				margin-top: auto;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.8rem;
				color: var(--text-muted);
				font-family: 'Cascadia Code', monospace;
				padding-top: 1.5rem;
				border-top: 1px solid rgba(255, 255, 255, 0.05);
			}

			.explore-text {
				color: var(--primary-cyan);
				opacity: 0.6;
				display: flex;
				align-items: center;
				gap: 0.5rem;
				transition: var(--transition-base);
			}

			.folder-card:hover .explore-text {
				opacity: 1;
				gap: 1rem;
			}

			@media (max-width: 768px) {
				.archive-header { padding: 8rem 0 4rem; }
				.header-title { font-size: 2.8rem; }
				.folder-grid { grid-template-columns: 1fr; }
				.archive-main { padding-bottom: 5rem; }
			}
		</style>
	</head>
	<body>
		<div class="noise-overlay"></div>
		<Header />

		<div class="archive-header">
			<canvas id="particle-canvas"></canvas>
			<div class="header-container">
				<span class="header-subtitle">FILE_SYSTEM / VOL_01</span>
				<h1 class="header-title">Archives.</h1>
			</div>
		</div>

		<main class="archive-main">
			<div class="folder-grid">
				{categories.map((category, index) => (
					<a
						href={`/blog/category/${category}`}
						class={`folder-card reveal stagger-${Math.min(index + 1, 6)}`}
					>
						<div class="folder-icon">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
							</svg>
						</div>
						<div class="folder-info">
							<h2>{category}</h2>
							<div class="folder-meta">
								<span>ENTRIES: <span class="post-count">{categoryData[category].count}</span></span>
							</div>
						</div>
						<div class="folder-footer">
							<span>LAST_MOD: {categoryData[category].latestDate.toISOString().split('T')[0]}</span>
							<span class="explore-text">
								READ_DIR 
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
									<line x1="5" y1="12" x2="19" y2="12"></line>
									<polyline points="12 5 19 12 12 19"></polyline>
								</svg>
							</span>
						</div>
					</a>
				))}
			</div>
		</main>

		<Footer />

		<script>
			// ===== 粒子网络背景动画 =====
			const canvas = document.getElementById('particle-canvas');
			const ctx = canvas.getContext('2d');
			let particles = [];
			let mouse = { x: null, y: null, radius: 150 };
			let animationId = null;
			let isActive = true;

			function resizeCanvas() {
				const header = document.querySelector('.archive-header');
				if (header) {
					canvas.width = header.offsetWidth;
					canvas.height = header.offsetHeight;
				}
			}

			class Particle {
				constructor() {
					this.x = Math.random() * canvas.width;
					this.y = Math.random() * canvas.height;
					this.vx = (Math.random() - 0.5) * 0.5;
					this.vy = (Math.random() - 0.5) * 0.5;
					this.size = Math.random() * 2 + 1;
				}

				update() {
					this.x += this.vx;
					this.y += this.vy;

					if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
					if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

					if (mouse.x != null) {
						let dx = mouse.x - this.x;
						let dy = mouse.y - this.y;
						let distance = Math.sqrt(dx * dx + dy * dy);
						if (distance < mouse.radius) {
							const force = (mouse.radius - distance) / mouse.radius;
							const directionX = dx / distance;
							const directionY = dy / distance;
							this.x -= directionX * force * 2;
							this.y -= directionY * force * 2;
						}
					}
				}

				draw() {
					ctx.beginPath();
					ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
					ctx.fillStyle = 'rgba(0, 243, 255, 0.5)';
					ctx.fill();
				}
			}

			function initParticles() {
				particles = [];
				const particleCount = Math.min(50, Math.floor((canvas.width * canvas.height) / 15000));
				for (let i = 0; i < particleCount; i++) {
					particles.push(new Particle());
				}
			}

			function connectParticles() {
				const maxDistance = 100;
				for (let i = 0; i < particles.length; i++) {
					for (let j = i + 1; j < particles.length; j++) {
						let dx = particles[i].x - particles[j].x;
						let dy = particles[i].y - particles[j].y;
						let distance = Math.sqrt(dx * dx + dy * dy);

						if (distance < maxDistance) {
							const opacity = (1 - distance / maxDistance) * 0.3;
							ctx.beginPath();
							ctx.strokeStyle = `rgba(0, 243, 255, ${opacity})`;
							ctx.lineWidth = 1;
							ctx.moveTo(particles[i].x, particles[i].y);
							ctx.lineTo(particles[j].x, particles[j].y);
							ctx.stroke();
						}
					}
				}
			}

			function animateParticles() {
				if (!isActive) return;
				ctx.clearRect(0, 0, canvas.width, canvas.height);

				particles.forEach(particle => {
					particle.update();
					particle.draw();
				});

				connectParticles();
				animationId = requestAnimationFrame(animateParticles);
			}

			const header = document.querySelector('.archive-header');
			header.addEventListener('mousemove', (e) => {
				const rect = header.getBoundingClientRect();
				mouse.x = e.clientX - rect.left;
				mouse.y = e.clientY - rect.top;
			});

			header.addEventListener('mouseleave', () => {
				mouse.x = null;
				mouse.y = null;
			});

			resizeCanvas();
			initParticles();
			animateParticles();

			window.addEventListener('resize', () => {
				resizeCanvas();
				initParticles();
			});

			document.addEventListener('visibilitychange', () => {
				isActive = document.visibilityState === 'visible';
				if (isActive && !animationId) animateParticles();
			});

			// ===== 滚动触发动画 =====
			const revealElements = document.querySelectorAll('.reveal');

			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');
						revealObserver.unobserve(entry.target);
					}
				});
			}, {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			});

			revealElements.forEach(el => revealObserver.observe(el));
		</script>
	</body>
</html>
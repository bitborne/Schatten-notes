---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const categories = [...new Set(posts.map(post => {
		const parts = post.id.split('/');
		return parts.length > 1 ? parts[0] : 'Notes';
	}))];
	
	return categories.map(category => ({
		params: { category },
		props: { 
			posts: posts.filter(post => {
				const folder = post.id.split('/').length > 1 ? post.id.split('/')[0] : 'Notes';
				return folder === category;
			}).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
		}
	}));
}

const { category } = Astro.params;
const { posts } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${category} | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			/* ===== 森林绿配色变量 ===== */
			:root {
				--forest-green: #2d5016;
				--forest-light: #4a7c2e;
				--forest-bright: #7cb342;
				--forest-cyan: #4db6ac;
				--forest-bg: #0d1a0d;
			}

			.category-header {
				padding: 10rem 0 4rem;
				position: relative;
				overflow: hidden;
				background:
					radial-gradient(at 0% 0%, rgba(77, 182, 172, 0.1) 0, transparent 50%),
					radial-gradient(at 100% 100%, rgba(124, 179, 66, 0.08) 0, transparent 45%),
					linear-gradient(180deg, var(--forest-bg) 0%, var(--bg-abyss) 100%);
			}

			/* 森林网格背景 */
			.category-header::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(77, 182, 172, 0.04) 1px, transparent 1px),
					linear-gradient(90deg, rgba(124, 179, 66, 0.03) 1px, transparent 1px);
				background-size: 40px 40px;
				-webkit-mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
				mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
				pointer-events: none;
			}

			/* 微光效果 */
			.category-header::after {
				content: '';
				position: absolute;
				top: 0; left: 0; right: 0; bottom: 0;
				background: radial-gradient(circle at 30% 30%, rgba(77, 182, 172, 0.1), transparent 40%);
				pointer-events: none;
			}

			.header-container {
				max-width: 1000px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.breadcrumb {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 1.5rem;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.breadcrumb a {
				color: var(--forest-cyan);
				text-shadow: 0 0 10px rgba(77, 182, 172, 0.3);
			}

			.breadcrumb span:last-child {
				color: var(--forest-bright);
			}

			.category-title {
				font-size: 3rem;
				font-weight: 800;
				margin: 0;
				background: linear-gradient(135deg, #fff 0%, var(--forest-cyan) 50%, var(--forest-bright) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				filter: drop-shadow(0 0 20px rgba(77, 182, 172, 0.2));
			}

			.main-content {
				max-width: 1000px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
			}

			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.post-item {
				display: grid;
				grid-template-columns: auto 1fr;
				gap: 2.5rem;
				padding: 2rem;
				background: rgba(13, 26, 13, 0.5);
				border: 1px solid rgba(77, 182, 172, 0.1);
				border-radius: var(--radius-md);
				transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
				text-decoration: none;
				position: relative;
				overflow: hidden;
			}

			.post-item::before {
				content: '';
				position: absolute;
				top: 0; left: 0; width: 3px; height: 100%;
				background: linear-gradient(180deg, var(--forest-cyan), var(--forest-bright));
				transform: scaleY(0);
				transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.post-item:hover {
				border-color: rgba(77, 182, 172, 0.3);
				transform: translateX(10px);
				box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(77, 182, 172, 0.1);
				background: rgba(13, 26, 13, 0.7);
			}

			.post-item:hover::before {
				transform: scaleY(1);
			}

			.post-date {
				font-family: 'Cascadia Code', monospace;
				font-size: 0.85rem;
				color: var(--forest-cyan);
				opacity: 0.7;
				padding-top: 0.4rem;
				white-space: nowrap;
			}

			.post-title {
				font-size: 1.4rem;
				color: var(--text-primary);
				margin-bottom: 0.8rem;
				transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.post-item:hover .post-title {
				color: var(--forest-bright);
				text-shadow: 0 0 20px rgba(124, 179, 66, 0.3);
			}

			.post-excerpt {
				color: var(--text-secondary);
				font-size: 1rem;
				line-height: 1.6;
				margin: 0;
			}

			@media (max-width: 768px) {
				.post-item { grid-template-columns: 1fr; gap: 0.5rem; padding: 1.5rem; }
				.category-title { font-size: 2rem; }
			}

			/* 滚动触发动画 */
			.reveal {
				opacity: 0;
				transform: translateY(30px);
				transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
			}

			.reveal.active {
				opacity: 1;
				transform: translateY(0);
			}

			.stagger-1 { transition-delay: 0.1s; }
			.stagger-2 { transition-delay: 0.2s; }
			.stagger-3 { transition-delay: 0.3s; }
			.stagger-4 { transition-delay: 0.4s; }
		</style>
	</head>
	<body>
		<Header />
		
		<div class="category-header">
			<div class="header-container">
				<nav class="breadcrumb">
					<a href="/blog">ARCHIVE</a>
					<span>/</span>
					<span>{category.toUpperCase()}</span>
				</nav>
				<h1 class="category-title">{category}</h1>
			</div>
		</div>

		<main class="main-content">
			<div class="posts-list">
				{posts.map((post, index) => (
					<a href={`/blog/${post.id}/`} class={`post-item reveal stagger-${Math.min(index % 4 + 1, 4)}`}>
						<div class="post-date">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<div class="post-content">
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-excerpt">{post.data.description || 'No summary available for this entry.'}</p>
						</div>
					</a>
				))}
			</div>
		</main>

		<Footer />

		<script>
			// ===== 滚动触发动画 =====
			const revealElements = document.querySelectorAll('.reveal');

			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');
						revealObserver.unobserve(entry.target);
					}
				});
			}, {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			});

			revealElements.forEach(el => revealObserver.observe(el));
		</script>
	</body>
</html>

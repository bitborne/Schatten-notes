---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const { showThemeToggle = false } = Astro.props;
---

<header class="site-header">
	<div class="header-glow"></div>
	<div class="header-container">
		<div class="logo">
			<a href="/" class="logo-link">
				<span class="logo-bracket">[</span>
				<span class="logo-prefix">$</span>
				<span class="logo-text">{SITE_TITLE}</span>
				<span class="logo-cursor">_</span>
				<span class="logo-bracket">]</span>
			</a>
		</div>

		<nav class="main-nav">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</nav>

		<div class="header-actions">
			{showThemeToggle && (
				<label class="header-theme-toggle" aria-label="切换主题">
					<input type="checkbox" id="headerThemeToggle" class="theme-toggle-input" />
					<span class="theme-toggle-thumb">
						<svg class="theme-toggle-icon theme-toggle-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
						</svg>
						<svg class="theme-toggle-icon theme-toggle-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
							<circle cx="12" cy="12" r="5" fill="currentColor" fill-opacity="0.3" stroke="currentColor" stroke-width="2">
							</circle>
							<line x1="12" y1="9" x2="12" y2="0" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="12" y1="15" x2="12" y2="24" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="9" y1="12" x2="0" y2="12" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="15" y1="12" x2="24" y2="12" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="9.5" y1="9.5" x2="3" y2="3" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="14.5" y1="14.5" x2="21" y2="21" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="14.5" y1="9.5" x2="21" y2="3" stroke-linecap="round" stroke-width="2.5">
							</line>
							<line x1="9.5" y1="14.5" x2="3" y2="21" stroke-linecap="round" stroke-width="2.5">
							</line>
						</svg>
					</span>
				</label>
			)}
			<a href="https://github.com/bitborne" target="_blank" class="github-link" aria-label="GitHub">
				<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
			</svg>
			</a>
			<button class="menu-toggle" aria-label="Toggle Menu" id="menuToggle">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</div>

	<div class="mobile-menu" id="mobileMenu">
		<nav class="mobile-nav">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</nav>
	</div>
</header>

<style>
	/* ===== 液态金属 Header ===== */
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: rgba(15, 13, 26, 0.6);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	/* 顶部发光条 */
	.header-glow {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(90deg,
			transparent 0%,
			rgba(99, 102, 241, 0.5) 20%,
			rgba(236, 72, 153, 0.5) 50%,
			rgba(99, 102, 241, 0.5) 80%,
			transparent 100%
		);
		opacity: 0;
		transition: opacity 0.4s;
	}

	.site-header.scrolled .header-glow {
		opacity: 1;
	}

	.site-header.scrolled {
		background: rgba(15, 13, 26, 0.9);
		border-bottom-color: rgba(99, 102, 241, 0.15);
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4), 0 0 60px rgba(99, 102, 241, 0.1);
	}

	.header-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.site-header.scrolled .header-container {
		padding: 0.75rem 1.5rem;
	}

	/* ===== Logo 设计 - 液态终端风格 ===== */
	.logo-link {
		display: flex;
		align-items: center;
		font-family: 'Cascadia Code', monospace;
		font-weight: 700;
		font-size: 1.1rem;
		letter-spacing: -0.01em;
		text-decoration: none;
		padding: 0.5rem 1rem;
		background: rgba(99, 102, 241, 0.08);
		border: 1px solid rgba(99, 102, 241, 0.15);
		border-radius: 12px;
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.logo-link:hover {
		background: rgba(99, 102, 241, 0.15);
		border-color: rgba(236, 72, 153, 0.3);
		box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
		transform: translateY(-1px);
	}

	.logo-bracket {
		color: rgba(148, 163, 184, 0.5);
		font-weight: 400;
	}

	.logo-prefix {
		background: linear-gradient(135deg, #6366f1, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0 0.2em;
		font-weight: 800;
	}

	.logo-text {
		color: #f8fafc;
		margin-right: 0.2em;
	}

	.logo-cursor {
		color: #6366f1;
		animation: blink 1.2s step-end infinite;
		text-shadow: 0 0 10px rgba(99, 102, 241, 0.5);
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	/* ===== 导航 - 液态悬浮效果 ===== */
	.main-nav {
		display: flex;
		gap: 0.25rem;
		padding: 0.25rem;
		background: rgba(255, 255, 255, 0.02);
		border-radius: 100px;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.main-nav :global(a) {
		padding: 0.5rem 1.25rem;
		color: #94a3b8;
		font-size: 0.9rem;
		font-weight: 500;
		border-radius: 100px;
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		text-decoration: none;
		position: relative;
		overflow: hidden;
	}

	.main-nav :global(a::before) {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(236, 72, 153, 0.2));
		border-radius: 100px;
		opacity: 0;
		transition: opacity 0.3s;
		z-index: -1;
	}

	.main-nav :global(a:hover) {
		color: #f8fafc;
		transform: translateY(-1px);
	}

	.main-nav :global(a:hover::before) {
		opacity: 1;
	}

	.main-nav :global(a.active) {
		color: #f8fafc;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.25), rgba(236, 72, 153, 0.15));
		box-shadow: 0 4px 15px rgba(99, 102, 241, 0.2);
	}

	/* ===== Header 操作区 - GitHub 和菜单按钮 ===== */
	.header-actions {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	/* ===== GitHub 链接 ===== */
	.github-link {
		color: #64748b;
		transition: all 0.3s;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.github-link:hover {
		color: #f8fafc;
		background: rgba(99, 102, 241, 0.1);
		border-color: rgba(99, 102, 241, 0.2);
		box-shadow: 0 0 20px rgba(99, 102, 241, 0.15);
		transform: translateY(-2px);
	}

	/* ===== 汉堡菜单 ===== */
	.menu-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
		width: 40px;
		height: 40px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 10px;
		cursor: pointer;
		padding: 0;
		transition: all 0.3s;
	}

	.menu-toggle:hover {
		background: rgba(99, 102, 241, 0.1);
		border-color: rgba(99, 102, 241, 0.2);
	}

	.menu-toggle span {
		display: block;
		width: 18px;
		height: 2px;
		background: linear-gradient(90deg, #6366f1, #ec4899);
		border-radius: 2px;
		transition: all 0.3s;
	}

	.menu-toggle.active span:nth-child(1) {
		transform: rotate(45deg) translate(5px, 5px);
	}

	.menu-toggle.active span:nth-child(2) {
		opacity: 0;
	}

	.menu-toggle.active span:nth-child(3) {
		transform: rotate(-45deg) translate(5px, -5px);
	}

	/* ===== 移动端菜单 ===== */
	.mobile-menu {
		display: none;
		background: rgba(15, 13, 26, 0.95);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid rgba(99, 102, 241, 0.1);
		padding: 1rem;
	}

	.mobile-menu.open {
		display: block;
	}

	.mobile-nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.mobile-nav :global(a) {
		padding: 0.75rem 1rem;
		border-radius: 8px;
	}

	/* ===== 响应式 ===== */
	@media (max-width: 768px) {
		.main-nav { display: none; }
		.menu-toggle { display: flex; }
		.logo-link { font-size: 1rem; padding: 0.4rem 0.8rem; }
	}

	@media (max-width: 480px) {
		.header-container { padding: 0.75rem 1rem; }
		.logo-link { font-size: 0.9rem; padding: 0.35rem 0.6rem; }
		.logo-bracket { display: none; }
	}

	@media (max-width: 360px) {
		.logo-text { display: none; }
		.logo-prefix::after { content: 'S'; }
	}

	/* ===== 浅色主题覆盖 - 使用:global确保正确匹配 ===== */
	:global([data-theme="light"]) .site-header {
		background: rgba(248, 250, 252, 0.85);
		border-bottom-color: rgba(0, 0, 0, 0.06);
	}

	:global([data-theme="light"]) .site-header.scrolled {
		background: rgba(241, 245, 249, 0.95);
	}

	:global([data-theme="light"]) .logo-text {
		background: linear-gradient(135deg, #0066cc, #7c4dff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:global([data-theme="light"]) .logo-prefix {
		background: linear-gradient(135deg, #0066cc, #7c4dff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	:global([data-theme="light"]) .logo-bracket {
		color: #64748b;
	}

	:global([data-theme="light"]) .logo-cursor {
		color: #0066cc;
	}

	:global([data-theme="light"]) .main-nav a {
		color: #4a5568;
	}

	:global([data-theme="light"]) .main-nav a:hover {
		background: rgba(0, 102, 204, 0.08);
		color: #0066cc;
	}

	:global([data-theme="light"]) .main-nav a.active {
		background: rgba(0, 102, 204, 0.12);
		color: #0066cc;
	}

	:global([data-theme="light"]) .github-link {
		background: rgba(0, 0, 0, 0.04);
		color: #4a5568;
		border-color: rgba(0, 0, 0, 0.08);
	}

	:global([data-theme="light"]) .github-link:hover {
		background: rgba(0, 102, 204, 0.1);
		color: #0066cc;
		border-color: rgba(0, 102, 204, 0.2);
	}

	:global([data-theme="light"]) .header-glow {
		background: linear-gradient(90deg,
			transparent,
			rgba(0, 102, 204, 0.2),
			rgba(124, 77, 255, 0.3),
			rgba(0, 102, 204, 0.2),
			transparent
		);
	}

	/* 强制覆盖深色主题阴影 */
	:global([data-theme="light"]) .site-header,
	:global([data-theme="light"]) .site-header.scrolled {
		background: rgba(241, 245, 249, 0.95) !important;
		border-bottom-color: rgba(0, 0, 0, 0.06) !important;
		box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08) !important;
	}

	:global([data-theme="light"]) .header-glow {
		opacity: 0.5 !important;
	}

	/* ===== Header 主题切换按钮 ===== */
	.header-theme-toggle {
		display: flex;
		align-items: center;
		cursor: pointer;
		width: 52px;
		height: 28px;
		background: linear-gradient(145deg, #1a1d2e, #121420);
		border-radius: 14px;
		padding: 2px;
		box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.4), inset -2px -2px 4px rgba(255, 255, 255, 0.05);
		transition: all 0.3s ease;
		position: relative;
		margin-right: 12px;
	}

	:global([data-theme="light"]) .header-theme-toggle {
		background: linear-gradient(145deg, #e8e8e8, #d0d0d0);
		box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.1), inset -2px -2px 4px rgba(255, 255, 255, 0.8);
	}

	.theme-toggle-input {
		display: none;
	}

	.theme-toggle-thumb {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		background: linear-gradient(145deg, #2a2d2e, #1a1d2e);
		border-radius: 50%;
		box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.4);
		transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		position: absolute;
		left: 3px;
		top: 3px;
	}

	:global([data-theme="light"]) .theme-toggle-thumb {
		background: linear-gradient(145deg, #ffffff, #e0e0e0);
		box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
		transform: translateX(24px);
	}

	.theme-toggle-icon {
		position: absolute;
		width: 18px;
		height: 18px;
		transition: all 0.3s ease;
	}

	.theme-toggle-icon-moon {
		opacity: 1;
		color: #a0aec0;
	}

	:global([data-theme="light"]) .theme-toggle-icon-moon {
		opacity: 0;
	}

	.theme-toggle-icon-sun {
		opacity: 0;
		color: #f6ad55;
		width: 22px !important;
		height: 22px !important;
	}

	:global([data-theme="light"]) .theme-toggle-icon-sun {
		opacity: 1;
	}

	.header-theme-toggle:hover {
		box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.3), inset -2px -2px 4px rgba(255, 255, 255, 0.08), 0 0 12px rgba(0, 243, 255, 0.3);
	}

	:global([data-theme="light"]) .header-theme-toggle:hover {
		box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.1), inset -2px -2px 4px rgba(255, 255, 255, 0.8), 0 0 12px rgba(255, 184, 108, 0.4);
	}
</style>

<script>
	// 滚动效果
	const header = document.querySelector('.site-header');

	window.addEventListener('scroll', () => {
		if (window.scrollY > 30) {
			header?.classList.add('scrolled');
		} else {
			header?.classList.remove('scrolled');
		}
	});

	// 移动端菜单
	const menuToggle = document.getElementById('menuToggle');
	const mobileMenu = document.getElementById('mobileMenu');

	menuToggle?.addEventListener('click', () => {
		menuToggle.classList.toggle('active');
		mobileMenu?.classList.toggle('open');
	});

	// Header 主题切换按钮逻辑
	const headerToggle = document.getElementById('headerThemeToggle');
	if (headerToggle) {
		// 根据当前主题设置初始状态
		const currentTheme = document.documentElement.getAttribute('data-theme');
		headerToggle.checked = currentTheme === 'light';

		// 监听切换事件
		headerToggle.addEventListener('change', function() {
			const newTheme = this.checked ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', newTheme);
			localStorage.setItem('blog-theme', newTheme);
		});
	}
</script>
